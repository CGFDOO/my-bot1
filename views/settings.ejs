                        <button type="button" onclick="sendLiveEmbed('<%= guildId %>')" class="w-full py-4 bg-fuchsia-600 hover:bg-fuchsia-500 text-white font-black text-xl rounded-xl transition-all shadow-lg" data-en="🚀 Send Embed to Discord Now!">
                            🚀 إرسال الإيمبد للديسكورد الآن!
                        </button>
                    </div>
                </div>

                <div id="section-middleman" class="settings-section max-w-5xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-black text-white mb-6 border-b border-dark-700 pb-4" data-en="Middleman System ⚖️">نظام الوساطة المعزول ⚖️</h2>
                    
                    <div class="glass-card rounded-3xl p-6 md:p-8 mb-8 border-t-4 border-t-amber-500 shadow-lg">
                        <div class="flex flex-col md:flex-row items-start md:items-center justify-between bg-dark-900/50 p-6 rounded-2xl border border-dark-700 mb-8 gap-4">
                            <div>

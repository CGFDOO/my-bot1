                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
                            <div class="bg-dark-800 p-4 rounded-xl border border-dark-600 text-center">
                                <label class="block text-xs font-bold text-slate-400 mb-2" data-en="Top Daily">التوب اليومي (Daily)</label>
                                <input type="text" name="lvl_topDailyCmd" value="<%= config.leveling?.topDailyCmd || 'topd' %>" class="w-full bg-dark-900 border border-dark-700 rounded-lg p-2.5 text-white font-mono text-sm text-center">
                            </div>
                            <div class="bg-dark-800 p-4 rounded-xl border border-dark-600 text-center">
                                <label class="block text-xs font-bold text-slate-400 mb-2" data-en="Top Weekly">التوب الأسبوعي (Weekly)</label>
                                <input type="text" name="lvl_topWeeklyCmd" value="<%= config.leveling?.topWeeklyCmd || 'topw' %>" class="w-full bg-dark-900 border border-dark-700 rounded-lg p-2.5 text-white font-mono text-sm text-center">
                            </div>
                            <div class="bg-dark-800 p-4 rounded-xl border border-dark-600 text-center">
                                <label class="block text-xs font-bold text-slate-400 mb-2" data-en="Top Monthly">التوب الشهري (Monthly)</label>
                                <input type="text" name="lvl_topMonthlyCmd" value="<%= config.leveling?.topMonthlyCmd || 'topm' %>" class="w-full bg-dark-900 border border-dark-700 rounded-lg p-2.5 text-white font-mono text-sm text-center">
                            </div>
                            <div class="bg-dark-800 p-4 rounded-xl border border-dark-600 text-center">
                                <label class="block text-xs font-bold text-brand-light mb-2" data-en="Top Global">التوب العام (All Time)</label>
                                <input type="text" name="lvl_topGlobalCmd" value="<%= config.leveling?.topGlobalCmd || 'top, توب' %>" class="w-full bg-dark-900 border border-dark-700 rounded-lg p-2.5 text-white font-mono text-sm text-center">
                            </div>
                        </div>

                        <div class="bg-dark-900/80 p-6 md:p-8 rounded-3xl border border-blue-500/30 shadow-inner">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 border-b border-dark-700 pb-4 gap-4">
                                <div>
                                    <h3 class="text-2xl font-bold text-brand-light" data-en="🎖️ Role Rewards">🎖️ جوائز الرتب للمستويات (Role Rewards)</h3>
                                    <p class="text-sm text-slate-400 mt-2" data-en="Member gets the role automatically at the specified level.">سيحصل العضو على الرتبة المحددة تلقائياً عند وصوله للمستوى المطلوب.</p>
                                </div>
                                <button type="button" onclick="addLevelRewardUI()" class="px-6 py-4 bg-blue-600 hover:bg-blue-500 text-white font-black text-sm rounded-xl transition-all shadow-lg whitespace-nowrap" data-en="➕ Add Role Reward">
                                    ➕ إضافة جائزة رتبة
                                </button>
                            </div>
                            
                            <div id="level-rewards-container" class="space-y-4"></div>
                        </div>
                    </div>
                </div>

            </form>
        </div>
    </main>

    <script>
        // 1. نظام القائمة الجانبية للموبايل
        function toggleMobileSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar.classList.contains('translate-x-full')) {
                sidebar.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        // 2. نظام التنقل السلس بين الأقسام
        function switchSection(target) {
            document.querySelectorAll('.settings-section').forEach(s => s.classList.remove('active'));
            document.getElementById('section-' + target).classList.add('active');
            
            document.querySelectorAll('.nav-btn').forEach(b => { 
                b.classList.remove('bg-brand','text-white'); 
                b.classList.add('text-slate-400'); 
            });
            const activeBtn = document.querySelector(`[data-target="${target}"]`);
            if(activeBtn) { 
                activeBtn.classList.add('bg-brand','text-white');
                activeBtn.classList.remove('text-slate-400'); 
            }
            if(window.innerWidth < 768) toggleMobileSidebar();
        }

        // 3. ذكاء زراير التكت الداخلي
        const hideBtn = document.getElementById('tc_hideTicketOnClaim');
        const readBtn = document.getElementById('tc_readOnlyStaffOnClaim');
        if (hideBtn && readBtn) {
            function syncTicketToggles() {
                if (hideBtn.checked) { 
                    readBtn.checked = false;
                    document.getElementById('read_claim_container').style.opacity = '0.4'; 
                    readBtn.disabled = true; 
                } else { 
                    document.getElementById('read_claim_container').style.opacity = '1';
                    readBtn.disabled = false; 
                }
                if (readBtn.checked) { 
                    hideBtn.checked = false;
                    document.getElementById('hide_claim_container').style.opacity = '0.4'; 
                    hideBtn.disabled = true; 
                } else if (!readBtn.checked && !hideBtn.checked) { 
                    document.getElementById('hide_claim_container').style.opacity = '1';
                    hideBtn.disabled = false; 
                }
            }
            hideBtn.addEventListener('change', syncTicketToggles);
            readBtn.addEventListener('change', syncTicketToggles);
            syncTicketToggles(); 
        }

        // 4. صانع الإيمبد الفوري
        async function sendLiveEmbed(guildId) {
            const channelId = document.getElementById('live_embed_channel').value;
            const title = document.getElementById('live_embed_title').value;
            const description = document.getElementById('live_embed_desc').value;
            const color = document.getElementById('live_embed_color').value;
            const imageUrl = document.getElementById('live_embed_image').value;
            const statusDiv = document.getElementById('live_embed_status');
            if(!channelId || (!title && !description)) { 
                statusDiv.className = 'mb-6 p-4 rounded-xl bg-red-500/20 text-red-400 border border-red-500';
                statusDiv.innerText = '❌ يرجى اختيار الروم وكتابة محتوى الإيمبد.'; 
                statusDiv.classList.remove('hidden'); 
                return;
            }
            statusDiv.className = 'mb-6 p-4 rounded-xl bg-blue-500/20 text-blue-400 border border-blue-500';
            statusDiv.innerText = '⏳ جاري الإرسال للديسكورد...'; 
            statusDiv.classList.remove('hidden');
            try {
                const res = await fetch(`/api/send-embed/${guildId}`, { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ channelId, title, description, color, imageUrl }) 
                });
                const data = await res.json();
                if(data.success) { 
                    statusDiv.className = 'mb-6 p-4 rounded-xl bg-emerald-500/20 text-emerald-400 border border-emerald-500';
                    statusDiv.innerText = '✅ تم الإرسال بنجاح!'; 
                    document.getElementById('live_embed_title').value = ''; 
                    document.getElementById('live_embed_desc').value = ''; 
                    document.getElementById('live_embed_image').value = '';
                } else { 
                    statusDiv.className = 'mb-6 p-4 rounded-xl bg-red-500/20 text-red-400 border border-red-500';
                    statusDiv.innerText = data.error || '❌ فشل الإرسال.'; 
                }
            } catch(e) { 
                statusDiv.className = 'mb-6 p-4 rounded-xl bg-red-500/20 text-red-400 border border-red-500';
                statusDiv.innerText = '❌ حدث خطأ في الاتصال بالبوت.'; 
            }
        }

        // ==========================================================
        // 🚀 المحركات الديناميكية لحفظ وعرض المصفوفات بأمان 🚀
        // ==========================================================
        const safeConfig = <%- JSON.stringify(config || {}) %>;
        let panelsArray = safeConfig.ticketPanels || [];
        let mmFields = safeConfig.middlemanSystem?.modalFields || [];
        let roleRewards = safeConfig.leveling?.roleRewards || [];
        let autoResponders = safeConfig.autoResponders || [];
        let commandRouting = safeConfig.commandRouting || [];
        let warnDataAr = safeConfig.warnings?.reasonsDataAr || [{"reason": "سب وشتم", "dmMessage": "لقد تم تحذيرك بسبب السب والشتم."}];
        let warnDataEn = safeConfig.warnings?.reasonsDataEn || [{"reason": "Swearing", "dmMessage": "You have been warned for swearing."}];

        // --- محرك توجيه الأوامر (Command Routing) ---
        const rChsHTML = `<%- textChannels.map(ch => `<option value="${ch.id}">${ch.name}</option>`).join('') %>`;
        function renderCommandRouting() {
            const container = document.getElementById('command-routing-container');
            container.innerHTML = '';
            if(commandRouting.length === 0) {
                container.innerHTML = '<div class="text-center text-slate-500 text-base p-8 border-2 border-dashed border-dark-600 rounded-2xl font-bold">لا يوجد توجيه مخصص لأي أمر حالياً. جميع الأوامر تعمل في أي روم.</div>';
                return;
            }
            commandRouting.forEach((route, idx) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-6 rounded-3xl border border-dark-600 relative shadow-xl hover:border-cyan-500/50 transition-colors">
                        <button type="button" onclick="commandRouting.splice(${idx}, 1); renderCommandRouting();" class="absolute top-4 left-4 text-red-400 bg-red-500/10 hover:bg-red-500 hover:text-white px-4 py-2 rounded-xl text-xs font-black transition-all shadow-sm">حذف 🗑️</button>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
                            <div>
                                <label class="block text-sm font-bold text-cyan-400 mb-2">الأمر (بدون برفكس)</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white font-mono text-sm focus:border-cyan-400 outline-none text-center" placeholder="مثال: rank" value="${route.command || ''}" onchange="commandRouting[${idx}].command = this.value">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-2">رومات يُسمح بكتابته فيها</label>
                                <select multiple class="w-full h-24 bg-dark-900 border border-dark-700 rounded-xl p-2 text-xs text-white custom-scrollbar focus:border-cyan-400 outline-none" onchange="commandRouting[${idx}].allowedChannels = Array.from(this.selectedOptions).map(o => o.value)">
                                    ${rChsHTML}
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-emerald-400 mb-2">رومات سيرد البوت فيها (اختياري)</label>
                                <select multiple class="w-full h-24 bg-dark-900 border border-dark-700 rounded-xl p-2 text-xs text-white custom-scrollbar focus:border-emerald-400 outline-none" onchange="commandRouting[${idx}].replyChannels = Array.from(this.selectedOptions).map(o => o.value)">
                                    ${rChsHTML}
                                </select>
                            </div>
                        </div>
                    </div>
                `;
                // Set selected values for multiple selects via JS after insertion
                setTimeout(() => {
                    const allowedSelect = container.querySelectorAll('select')[idx * 2];
                    const replySelect = container.querySelectorAll('select')[(idx * 2) + 1];
                    (route.allowedChannels || []).forEach(val => {
                        const opt = allowedSelect.querySelector(`option[value="${val}"]`);
                        if(opt) opt.selected = true;
                    });
                    (route.replyChannels || []).forEach(val => {
                        const opt = replySelect.querySelector(`option[value="${val}"]`);
                        if(opt) opt.selected = true;
                    });
                }, 0);
            });
        }
        function addCommandRoutingUI() { commandRouting.push({command: 'rank', allowedChannels: [], replyChannels: []}); renderCommandRouting(); }

        // --- محرك الردود التلقائية ---
        function renderAutoResponders() {
            const container = document.getElementById('auto-responders-container');
            container.innerHTML = '';
            if(autoResponders.length === 0) {
                container.innerHTML = '<div class="text-center text-slate-500 text-base p-8 border-2 border-dashed border-dark-600 rounded-2xl font-bold">لا توجد ردود تلقائية حالياً.</div>';
                return;
            }
            autoResponders.forEach((resp, idx) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-4 relative shadow-md hover:border-fuchsia-500/50 transition-colors">
                        <button type="button" onclick="autoResponders.splice(${idx}, 1); renderAutoResponders();" class="absolute top-4 left-4 text-red-400 bg-red-500/10 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg text-xs font-bold transition-all">حذف 🗑️</button>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-400 mb-2">الكلمة التي يكتبها العضو</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white font-bold focus:border-brand outline-none" placeholder="مثال: السلام عليكم" value="${resp.trigger || ''}" onchange="autoResponders[${idx}].trigger = this.value">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-400 mb-2">رد البوت (نص أو رابط)</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white focus:border-brand outline-none" placeholder="مثال: وعليكم السلام ورحمة الله" value="${resp.reply || ''}" onchange="autoResponders[${idx}].reply = this.value">
                            </div>
                        </div>
                    </div>
                `;
            });
        }
        function addAutoResponderUI() { autoResponders.push({trigger: 'كلمة', reply: 'رد'}); renderAutoResponders(); }

        // --- محرك التحذيرات ---
        function renderWarns(lang) {
            const arr = lang === 'ar' ? warnDataAr : warnDataEn;
            const container = document.getElementById(`warn-${lang}-container`);
            if(!container) return;
            container.innerHTML = '';
            arr.forEach((item, index) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-4 transition-all shadow-md relative group hover:border-red-500/50">
                        <button type="button" onclick="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}.splice(${index}, 1); renderWarns('${lang}');" class="absolute top-4 left-4 text-red-500 bg-red-500/10 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg text-xs font-bold transition-all opacity-100 md:opacity-0 md:group-hover:opacity-100">حذف 🗑️</button>
                        <label class="block text-sm font-bold text-slate-400 mb-2">السبب (يظهر في زر البانل):</label>
                        <input type="text" class="w-full bg-dark-900 border border-dark-700 text-white text-base rounded-xl p-3 font-bold mb-4 focus:border-brand outline-none ${lang === 'en' ? 'text-left' : ''}" dir="${lang === 'en' ? 'ltr' : 'rtl'}" value="${item.reason}" onchange="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}[${index}].reason = this.value">
                        <label class="block text-sm font-bold text-brand-light mb-2">رسالة الخاص للعضو (DM Message):</label>
                        <textarea class="w-full bg-dark-900 border border-dark-700 text-white text-sm rounded-xl p-4 resize-y focus:border-brand outline-none ${lang === 'en' ? 'text-left' : ''}" dir="${lang === 'en' ? 'ltr' : 'rtl'}" rows="3" onchange="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}[${index}].dmMessage = this.value">${item.dmMessage}</textarea>
                    </div>
                `;
            });
        }
        function addWarnReason(lang) { 
            if(lang === 'ar') warnDataAr.push({reason: 'سبب جديد', dmMessage: 'لقد تم تحذيرك بسبب...'}); 
            else warnDataEn.push({reason: 'New Reason', dmMessage: 'You have been warned for...'}); 
            renderWarns(lang); 
        }

        // --- محرك أسئلة نافذة الوساطة ---
        function renderMmFields() {
            const container = document.getElementById('mm-fields-ui-container'); 
            container.innerHTML = '';
            if(mmFields.length === 0) {
                container.innerHTML = '<div class="text-center text-slate-500 text-base p-6 border-2 border-dashed border-dark-600 rounded-2xl font-bold">لا توجد أسئلة للنافذة حالياً. العميل سيفتح التذكرة فوراً.</div>';
                return;
            }
            mmFields.forEach((field, index) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-5 relative shadow-md">
                        <div class="absolute top-0 right-0 bg-dark-700 text-xs px-4 py-1.5 rounded-bl-xl text-slate-300 font-bold">السؤال ${index + 1}</div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                            <div>
                                <label class="text-sm font-bold text-slate-400 mb-2 block">نص السؤال</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white text-base font-bold focus:border-brand outline-none" value="${field.label || ''}" onchange="mmFields[${index}].label = this.value">
                            </div>
                            <div>
                                <label class="text-sm font-bold text-slate-400 mb-2 block">مثال إرشادي (Placeholder)</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white text-sm focus:border-brand outline-none" placeholder="مثال للعميل..." value="${field.placeholder || ''}" onchange="mmFields[${index}].placeholder = this.value">
                            </div>
                        </div>
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mt-6 pt-5 border-t border-dark-700 gap-4">
                            <div class="flex flex-col space-y-3 text-sm font-bold text-brand-light bg-dark-900/50 p-4 rounded-xl border border-dark-600 w-full md:w-auto">
                                <label class="cursor-pointer flex items-center">
                                    <input type="radio" name="mm_style_${index}" value="Short" class="mr-3 ml-3 w-5 h-5 accent-brand" ${field.style !== 'Paragraph' ? 'checked' : ''} onchange="mmFields[${index}].style = this.value"> إجابة قصيرة (سطر واحد)
                                </label>
                                <label class="cursor-pointer flex items-center">
                                    <input type="radio" name="mm_style_${index}" value="Paragraph" class="mr-3 ml-3 w-5 h-5 accent-brand" ${field.style === 'Paragraph' ? 'checked' : ''} onchange="mmFields[${index}].style = this.value"> إجابة طويلة (فقرة كبيرة)
                                </label>
                            </div>
                            <button type="button" onclick="mmFields.splice(${index}, 1); renderMmFields();" class="w-full md:w-auto text-sm bg-red-600 hover:bg-red-500 text-white px-6 py-3 rounded-xl font-bold transition-all shadow-md">حذف السؤال 🗑️</button>
                        </div>
                    </div>
                `;
            });
        }
        function addMmFieldUI() { mmFields.push({ label: 'سؤال جديد', placeholder: 'اكتب إجابتك هنا...', style: 'Short' }); renderMmFields(); }

        // --- محرك جوائز اللفلات ---
        const sRolesHTML = `<%- serverRoles.map(r => `<option value="${r.id}">${r.name}</option>`).join('') %>`;
        function renderLvlRewards() {
            const container = document.getElementById('level-rewards-container');
            container.innerHTML = '';
            if(roleRewards.length === 0){ 
                container.innerHTML = '<div class="text-center text-slate-500 text-base p-8 border-2 border-dashed border-dark-600 rounded-2xl font-bold">لم تقم بإضافة أي جوائز رتب للـ مستويات حتى الآن.</div>';
                return; 
            }
            roleRewards.forEach((reward, index) => {
                container.innerHTML += `
                    <div class="flex flex-col md:flex-row items-center space-x-0 md:space-x-6 md:space-x-reverse space-y-4 md:space-y-0 bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-3 shadow-lg hover:border-blue-500/50 transition-colors">
                        <div class="flex items-center w-full md:w-auto">
                            <span class="text-brand-light font-black text-base w-40">عند الوصول لـ لفل:</span>
                            <input type="number" min="1" class="w-24 bg-dark-900 border border-dark-600 rounded-xl py-3 px-3 text-white font-black text-center text-xl focus:border-brand outline-none" value="${reward.levelRequired}" onchange="roleRewards[${index}].levelRequired = parseInt(this.value)">
                        </div>
                        <div class="flex items-center w-full md:flex-1">
                            <span class="text-slate-400 font-bold text-base w-24">يأخذ رتبة:</span>
                            <select class="flex-1 bg-dark-900 border border-dark-600 rounded-xl py-3 px-4 text-white font-bold cursor-pointer focus:border-brand outline-none" onchange="roleRewards[${index}].roleId = this.value">
                                <option value="">-- يرجى اختيار الرتبة --</option>
                                ${sRolesHTML.replace(`value="${reward.roleId}"`, `value="${reward.roleId}" selected`)}
                            </select>
                        </div>
                        <button type="button" onclick="roleRewards.splice(${index}, 1); renderLvlRewards();" class="w-full md:w-auto bg-red-600 hover:bg-red-500 text-white px-8 py-3 rounded-xl font-black transition-all shadow-md">إزالة 🗑️</button>
                    </div>
                `;
            });
        }
        function addLevelRewardUI() { roleRewards.push({ levelRequired: 5, roleId: '' }); renderLvlRewards(); }

        // --- 🛡️ المحرك العملاق للبانلات والنوافذ 🛡️ ---
        const catsHTML = `<%- categories.map(cat => `<option value="${cat.id}">${cat.name}</option>`).join('') %>`;
        const chsHTML = `<%- textChannels.map(ch => `<option value="${ch.id}">${ch.name}</option>`).join('') %>`;
        
        function renderAllPanels() {
            const container = document.getElementById('dynamic-panels-container'); 
            container.innerHTML = '';
            
            if(panelsArray.length === 0) { 
                container.innerHTML = `<div class="text-center p-12 bg-dark-900/50 rounded-3xl border-2 border-dashed border-dark-700 text-slate-500 font-bold text-lg">لا توجد بانلات تذاكر حالياً. ابدأ بإضافة أول بانل لك.</div>`; 
                return; 
            }

            panelsArray.forEach((panel, pIdx) => {
                let buttonsHTML = '';
                (panel.buttons || []).forEach((btn, bIdx) => {
                    let modalHTML = '';
                    if(btn.requireModal) {
                        modalHTML += `
                            <div class="mt-6 p-6 bg-dark-900/80 rounded-2xl border border-dark-700 shadow-inner">
                                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 border-b border-dark-600 pb-4 gap-4">
                                    <span class="text-base font-bold text-brand-light">📝 أسئلة النافذة المنبثقة (ستعرض الإجابات في Code Blocks)</span>
                                    <button type="button" onclick="if(!panelsArray[${pIdx}].buttons[${bIdx}].modalFields) panelsArray[${pIdx}].buttons[${bIdx}].modalFields=[]; panelsArray[${pIdx}].buttons[${bIdx}].modalFields.push({label:'',placeholder:'',style:'Short'}); renderAllPanels();" class="text-sm bg-brand hover:bg-brand-light text-white px-5 py-2.5 rounded-xl font-bold transition-all shadow-md w-full md:w-auto">➕ إضافة سؤال</button>
                                </div>
                        `;
                        (btn.modalFields || []).forEach((mf, mIdx) => {
                            modalHTML += `
                                <div class="flex flex-col space-y-4 mb-5 bg-dark-800 p-5 rounded-2xl border border-dark-600 relative">
                                    <button type="button" onclick="panelsArray[${pIdx}].buttons[${bIdx}].modalFields.splice(${mIdx},1); renderAllPanels();" class="absolute top-4 left-4 bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-bold transition-all shadow-sm text-xs">حذف</button>
                                    <div class="flex flex-col md:flex-row gap-4 mt-4">
                                        <input type="text" class="w-full md:w-1/2 bg-dark-900 border border-dark-700 text-sm text-white rounded-xl p-3.5 font-bold focus:border-brand outline-none" placeholder="السؤال الذي سيظهر للعميل" value="${mf.label}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].label=this.value">
                                        <input type="text" class="w-full md:w-1/2 bg-dark-900 border border-dark-700 text-sm text-white rounded-xl p-3.5 focus:border-brand outline-none" placeholder="مثال إرشادي للإجابة (اختياري)" value="${mf.placeholder}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].placeholder=this.value">
                                    </div>
                                    <div class="flex flex-col space-y-3 bg-dark-900/50 p-4 rounded-xl border border-dark-700 w-full md:w-1/2">
                                        <label class="cursor-pointer flex items-center text-sm font-bold text-brand-light">
                                            <input type="radio" name="p_${pIdx}_b_${bIdx}_m_${mIdx}" value="Short" class="mr-3 ml-3 w-5 h-5 accent-brand" ${mf.style !== 'Paragraph' ? 'checked' : ''} onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].style=this.value"> إجابة قصيرة (سطر واحد)
                                        </label>
                                        <label class="cursor-pointer flex items-center text-sm font-bold text-brand-light">
                                            <input type="radio" name="p_${pIdx}_b_${bIdx}_m_${mIdx}" value="Paragraph" class="mr-3 ml-3 w-5 h-5 accent-brand" ${mf.style === 'Paragraph' ? 'checked' : ''} onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].style=this.value"> إجابة طويلة (فقرة كبيرة)
                                        </label>
                                    </div>
                                </div>
                            `;
                        });
                        modalHTML += `</div>`;
                    }

                    buttonsHTML += `
                        <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 mb-8 relative shadow-xl">
                            <button type="button" onclick="panelsArray[${pIdx}].buttons.splice(${bIdx},1); renderAllPanels();" class="absolute top-5 left-5 text-red-400 bg-red-500/10 hover:bg-red-500 hover:text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all">حذف هذا الزر 🗑️</button>
                            <h5 class="text-xl font-black text-white mb-8 border-b border-dark-700 pb-4">🔘 إعدادات الزر رقم ${bIdx + 1}</h5>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                                <div>
                                    <label class="text-sm font-bold text-slate-400 block mb-3">اسم الزر (الذي سيظهر للعميل)</label>
                                    <input type="text" class="w-full bg-dark-900 border border-dark-700 text-base text-white font-bold rounded-xl p-4 focus:border-brand outline-none" value="${btn.label}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].label=this.value">
                                </div>
                                <div>
                                    <label class="text-sm font-bold text-slate-400 block mb-3">لون الزر (ستايل ديسكورد)</label>
                                    <select class="w-full bg-dark-900 border border-dark-700 text-base font-bold text-white rounded-xl p-4 cursor-pointer outline-none" onchange="panelsArray[${pIdx}].buttons[${bIdx}].buttonStyle=this.value">
                                        <option value="Primary" ${btn.buttonStyle === 'Primary' ? 'selected' : ''}>أزرق (Primary)</option>
                                        <option value="Success" ${btn.buttonStyle === 'Success' ? 'selected' : ''}>أخضر (Success)</option>
                                        <option value="Danger" ${btn.buttonStyle === 'Danger' ? 'selected' : ''}>أحمر (Danger)</option>
                                        <option value="Secondary" ${btn.buttonStyle === 'Secondary' ? 'selected' : ''}>رمادي (Secondary)</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="flex flex-col md:flex-row items-start md:items-center md:space-x-8 md:space-x-reverse space-y-4 md:space-y-0 text-base font-bold bg-dark-900/60 p-6 rounded-2xl border border-dark-700 mb-8 shadow-inner">
                                <label class="text-amber-400 flex items-center cursor-pointer w-full md:w-auto">
                                    <input type="checkbox" ${btn.isMiddleman ? 'checked' : ''} onchange="panelsArray[${pIdx}].buttons[${bIdx}].isMiddleman=this.checked" class="mr-3 ml-3 w-6 h-6 accent-amber-400"> 🤝 تفعيل نظام الوساطة لهذا الزر
                                </label>
                                <label class="text-emerald-400 flex items-center cursor-pointer w-full md:w-auto">
                                    <input type="checkbox" ${btn.requireModal ? 'checked' : ''} onchange="panelsArray[${pIdx}].buttons[${bIdx}].requireModal=this.checked; if(this.checked && !panelsArray[${pIdx}].buttons[${bIdx}].modalFields) panelsArray[${pIdx}].buttons[${bIdx}].modalFields=[]; renderAllPanels();" class="mr-3 ml-3 w-6 h-6 accent-emerald-400"> 📝 طلب أسئلة منبثقة (Modal) قبل الفتح
                                </label>
                            </div>
                            
                            <h6 class="text-lg font-black text-brand-light mb-6 mt-8 border-t border-dark-700 pt-6">🎨 إيمبد التذكرة الداخلي الخاص بهذا الزر:</h6>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                <div>
                                    <label class="text-xs font-bold text-slate-400 block mb-2">عنوان الإيمبد الداخلي (Title)</label>
                                    <input type="text" class="w-full bg-dark-900 border border-dark-700 text-sm text-white rounded-xl p-4 font-bold focus:border-brand outline-none" placeholder="مثال: تذكرة الدعم الفني" value="${btn.insideEmbedTitle || 'تذكرة جديدة'}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].insideEmbedTitle=this.value">
                                </div>
                                <div>
                                    <label class="text-xs font-bold text-slate-400 block mb-2">وصف الإيمبد الداخلي (Description)</label>
                                    <input type="text" class="w-full bg-dark-900 border border-dark-700 text-sm text-white rounded-xl p-4 focus:border-brand outline-none" placeholder="أهلاً بك في التذكرة، يرجى الانتظار..." value="${btn.insideEmbedDesc || ''}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].insideEmbedDesc=this.value">
                                </div>
                                <div class="md:col-span-2 bg-dark-900/40 p-6 rounded-2xl border border-dark-700 shadow-inner">
                                    <label class="text-sm font-black text-amber-400 block mb-4">🎨 لون إيمبد إجابات النافذة المخصص (المربعات - Code Blocks)</label>
                                    <div class="flex items-center space-x-6 space-x-reverse">
                                        <input type="color" class="w-16 h-14 bg-dark-900 rounded-xl p-1.5 cursor-pointer border-2 border-dark-600 shadow-sm" value="${btn.modalAnswersEmbedColor || '#2b2d31'}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalAnswersEmbedColor=this.value">
                                        <input type="text" class="flex-1 bg-dark-900 text-lg font-mono uppercase text-center rounded-xl border border-dark-600 py-3" value="${btn.modalAnswersEmbedColor || '#2b2d31'}" readonly>
                                    </div>
                                </div>
                            </div>
                            ${modalHTML}
                        </div>
                    `;
                });

                container.innerHTML += `
                    <div class="bg-dark-900/80 border-2 border-blue-500/40 rounded-[2.5rem] p-6 md:p-10 relative shadow-[0_10px_40px_rgba(0,0,0,0.5)] mb-12">
                        <button type="button" onclick="panelsArray.splice(${pIdx},1); renderAllPanels();" class="absolute top-6 left-6 md:top-8 md:left-8 bg-red-600 hover:bg-red-500 text-white px-4 md:px-6 py-2 md:py-3.5 rounded-xl text-sm md:text-base font-black shadow-lg transition-all transform hover:scale-105 border border-red-400">حذف البانل 🗑️</button>
                        
                        <div class="flex flex-col md:flex-row md:items-center space-y-4 md:space-y-0 md:space-x-6 md:space-x-reverse mb-10 border-b-2 border-dark-700 pb-8 mt-10 md:mt-0">
                            <input type="color" class="w-20 h-20 rounded-2xl bg-dark-800 p-2 cursor-pointer border-2 border-dark-600 shadow-inner hidden md:block" value="${panel.panelColor || '#5865F2'}" onchange="panelsArray[${pIdx}].panelColor=this.value" title="لون البانل الخارجي">
                            <div class="flex-1 w-full">
                                <label class="text-sm font-bold text-slate-400 block mb-2">عنوان البانل الخارجي (الذي سيظهر في الروم)</label>
                                <input type="text" class="bg-transparent text-3xl md:text-4xl font-black text-white focus:border-b-4 focus:border-brand outline-none w-full md:w-3/4 pb-2 transition-all" placeholder="مثال: لوحة الدعم الفني" value="${panel.panelTitle || ''}" onchange="panelsArray[${pIdx}].panelTitle=this.value">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                            <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 shadow-inner">
                                <label class="text-base font-bold text-slate-300 block mb-4">روم إرسال البانل</label>
                                <select class="w-full bg-dark-900 text-white font-bold text-lg rounded-xl p-4 cursor-pointer outline-none border border-dark-700 focus:border-brand" onchange="panelsArray[${pIdx}].channelId=this.value">
                                    <option value="">-- يرجى اختيار الروم --</option>
                                    ${chsHTML.replace(`value="${panel.channelId}"`, `value="${panel.channelId}" selected`)}
                                </select>
                            </div>
                            <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 shadow-inner">
                                <label class="text-base font-bold text-slate-300 block mb-4">قسم فتح التذاكر (Category)</label>
                                <select class="w-full bg-dark-900 text-white font-bold text-lg rounded-xl p-4 cursor-pointer outline-none border border-dark-700 focus:border-brand" onchange="panelsArray[${pIdx}].categoryId=this.value">
                                    <option value="">-- يرجى اختيار القسم --</option>
                                    ${catsHTML.replace(`value="${panel.categoryId}"`, `value="${panel.categoryId}" selected`)}
                                </select>
                            </div>
                            <div class="md:col-span-2 bg-dark-800 p-6 rounded-2xl border border-dark-700 shadow-inner">
                                <label class="text-base font-bold text-slate-300 block mb-4">وصف البانل الخارجي (Description)</label>
                                <textarea class="w-full bg-dark-900 text-white text-lg rounded-xl p-5 outline-none resize-y border border-dark-700 focus:border-brand leading-relaxed font-bold" rows="3" placeholder="اكتب هنا الوصف الذي سيظهر للأعضاء في الإيمبد الخارجي..." onchange="panelsArray[${pIdx}].panelDescription=this.value">${panel.panelDescription || ''}</textarea>
                            </div>
                        </div>

                        <div class="p-6 md:p-8 bg-dark-900/60 rounded-3xl border border-dark-700 shadow-inner">
                            <h4 class="text-2xl md:text-3xl font-black text-brand-light mb-8">🔘 أزرار البانل</h4>
                            ${buttonsHTML}
                            <button type="button" onclick="panelsArray[${pIdx}].buttons.push({id:'btn_'+Math.random().toString(36).substr(2,7),label:'زر جديد',buttonStyle:'Primary',requireModal:false,insideEmbedTitle:'تذكرة جديدة',modalAnswersEmbedColor:'#2b2d31'}); renderAllPanels();" class="w-full mt-6 py-6 border-4 border-dashed border-brand/40 bg-brand/5 hover:bg-brand/20 rounded-2xl text-brand-light font-black text-lg md:text-xl transition-all shadow-md transform hover:-translate-y-1">➕ إضافة زر جديد لهذا البانل</button>
                        </div>
                    </div>
                `;
            });
        }

        function addNewPanelUI() { 
            panelsArray.push({
                panelId: 'pnl_' + Math.random().toString(36).substr(2,7), 
                panelTitle: 'بانل تذاكر جديد', 
                panelColor: '#5865F2', 
                panelDescription: 'لطلب الدعم الفني يرجى الضغط على الزر أدناه.',
                buttons: []
            });
            renderAllPanels(); 
        }

        // -----------------------------------------------------------
        // 🔄 دالة الحفظ التي لا تقهر (لمنع مسح البيانات نهائياً) 🔄
        // -----------------------------------------------------------
        function submitMegaForm() {
            document.getElementById('warn_reasonsDataAr').value = JSON.stringify(warnDataAr);
            document.getElementById('warn_reasonsDataEn').value = JSON.stringify(warnDataEn);
            document.getElementById('mm_modalFieldsData').value = JSON.stringify(mmFields);
            document.getElementById('ticketPanelsData').value = JSON.stringify(panelsArray);
            document.getElementById('lvl_roleRewardsData').value = JSON.stringify(roleRewards);
            document.getElementById('autoRespondersData').value = JSON.stringify(autoResponders);
            document.getElementById('cmd_routingData').value = JSON.stringify(commandRouting);
            
            const saveBtn = document.querySelector('button[onclick="submitMegaForm()"]');
            saveBtn.innerHTML = '<span class="mr-3 ml-2 text-3xl animate-spin">⏳</span> جاري الحفظ وتحديث السيرفر...';
            saveBtn.classList.replace('bg-emerald-500', 'bg-emerald-700');
            saveBtn.classList.replace('border-emerald-400/50', 'border-emerald-700');
            saveBtn.classList.remove('hover:bg-emerald-400', 'hover:-translate-y-2');
            setTimeout(() => {
                document.getElementById('mega-settings-form').submit();
            }, 100);
        }

        // -----------------------------------------------------------
        // 🌍 محرك الترجمة الديناميكي للداشبورد (LRT & RTL)
        // -----------------------------------------------------------
        const systemLang = document.getElementById('system-language');
        function applyDashboardLanguage() {
            const isEnglish = systemLang && systemLang.value === 'en';
            if(isEnglish) {
                document.documentElement.setAttribute('dir', 'ltr');
                document.documentElement.setAttribute('lang', 'en');
                document.body.style.fontFamily = "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif";
                document.querySelectorAll('[data-en]').forEach(el => {
                    if(!el.hasAttribute('data-ar')) el.setAttribute('data-ar', el.innerText);
                    el.innerText = el.getAttribute('data-en');
                });
                document.getElementById('save-btn-text').innerText = "Save Settings Now";
            } else {
                document.documentElement.setAttribute('dir', 'rtl');
                document.documentElement.setAttribute('lang', 'ar');
                document.body.style.fontFamily = "'Tajawal', sans-serif";
                document.querySelectorAll('[data-ar]').forEach(el => {
                    el.innerText = el.getAttribute('data-ar');
                });
                document.getElementById('save-btn-text').innerText = "حفظ التعديلات الآن";
            }
            renderWarns(isEnglish ? 'en' : 'ar');
        }
        
        if(systemLang) {
            systemLang.addEventListener('change', applyDashboardLanguage);
            setTimeout(applyDashboardLanguage, 100); 
        }

        // -----------------------------------------------------------
        // 🚀 تشغيل جميع المحركات عند تحميل الصفحة
        // -----------------------------------------------------------
        window.onload = () => { 
            renderWarns('ar');
            renderWarns('en'); 
            renderMmFields(); 
            renderAllPanels(); 
            renderLvlRewards();
            renderAutoResponders();
            renderCommandRouting();
            
            // إخفاء إشعار الحفظ بعد 5 ثواني
            const alert = document.querySelector('.pop-down-alert');
            if(alert) {
                setTimeout(() => {
                    alert.style.display = 'none';
                }, 5000);
            }
        };
    </script>
</body>
</html>

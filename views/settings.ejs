                            </div>
                            <div class="md:col-span-2 bg-dark-800 p-8 rounded-3xl border border-dark-600 shadow-inner">
                                <label class="text-lg font-bold text-slate-300 block mb-4">وصف البانل الخارجي (Description)</label>
                                <textarea class="w-full bg-dark-900 text-white text-xl rounded-2xl p-6 outline-none resize-y border border-dark-700 focus:border-brand leading-relaxed font-bold" rows="3" onchange="panelsArray[${pIdx}].panelDescription=this.value">${panel.panelDescription || ''}</textarea>
                            </div>
                        </div>

                        <div class="p-8 md:p-10 bg-dark-900/60 rounded-[2rem] border border-dark-700 shadow-inner">
                            <h4 class="text-3xl md:text-4xl font-black text-brand-light mb-10">🔘 أزرار البانل</h4>
                            ${buttonsHTML}

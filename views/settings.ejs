                        (btn.modalFields || []).forEach((mf, mIdx) => {
                            modalHTML += `
                                <div class="flex flex-col space-y-5 mb-6 bg-dark-800 p-6 rounded-2xl border border-dark-600 relative shadow-md">
                                    <button type="button" onclick="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields.splice(${mIdx},1); renderMiddlemanPanels();" class="absolute top-5 left-5 bg-red-600 hover:bg-red-500 text-white px-5 py-2.5 rounded-lg font-black transition-all shadow-sm text-xs">حذف السؤال 🗑️</button>
                                    
                                    <div class="flex flex-col md:flex-row gap-6 mt-4">
                                        <div class="w-full md:w-1/2">
                                            <label class="block text-xs font-bold text-slate-400 mb-2">نص السؤال (مثال: اسم اللعبة)</label>
                                            <input type="text" class="w-full bg-dark-900 border border-dark-700 text-base text-white rounded-xl p-4 font-bold focus:border-amber-500 outline-none" value="${mf.label}" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].label=this.value">
                                        </div>
                                        <div class="w-full md:w-1/2">
                                            <label class="block text-xs font-bold text-slate-400 mb-2">مثال إرشادي (اختياري)</label>
                                            <input type="text" class="w-full bg-dark-900 border border-dark-700 text-base text-white rounded-xl p-4 focus:border-amber-500 outline-none" value="${mf.placeholder || ''}" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].placeholder=this.value">
                                        </div>
                                    </div>
                                    
                                    <div class="flex flex-col space-y-4 bg-dark-900/50 p-5 rounded-xl border border-dark-700 w-full md:w-1/2">
                                        <label class="cursor-pointer flex items-center text-sm font-bold text-amber-200">
                                            <input type="radio" name="mm_p_${pIdx}_b_${bIdx}_m_${mIdx}" value="Short" class="mr-4 ml-4 w-5 h-5 accent-amber-500" ${mf.style !== 'Paragraph' ? 'checked' : ''} onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].style=this.value"> إجابة قصيرة
                                        </label>
                                        <label class="cursor-pointer flex items-center text-sm font-bold text-amber-200">
                                            <input type="radio" name="mm_p_${pIdx}_b_${bIdx}_m_${mIdx}" value="Paragraph" class="mr-4 ml-4 w-5 h-5 accent-amber-500" ${mf.style === 'Paragraph' ? 'checked' : ''} onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].style=this.value"> إجابة طويلة
                                        </label>
                                    </div>
                                </div>
                            `;
                        });
                        modalHTML += `</div>`;
                    }

                    buttonsHTML += `
                        <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 mb-10 relative shadow-2xl">
                            <button type="button" onclick="middlemanPanelsArray[${pIdx}].buttons.splice(${bIdx},1); renderMiddlemanPanels();" class="absolute top-6 left-6 text-red-400 bg-red-500/10 hover:bg-red-500 hover:text-white px-6 py-3 rounded-xl text-sm font-black transition-all">حذف هذا الزر 🗑️</button>
                            <h5 class="text-2xl font-black text-white mb-8 border-b border-dark-700 pb-4">🔘 إعدادات الزر رقم ${bIdx + 1}</h5>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                                <div>
                                    <label class="text-sm font-bold text-slate-400 block mb-3">اسم الزر (مثال: وساطة سيرفرات)</label>
                                    <input type="text" class="w-full bg-dark-900 border border-dark-700 text-lg text-white font-bold rounded-xl p-4 focus:border-amber-500 outline-none shadow-inner" value="${btn.label}" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].label=this.value">
                                </div>
                                <div>
                                    <label class="text-sm font-bold text-slate-400 block mb-3">لون الزر (ستايل ديسكورد)</label>
                                    <select class="w-full bg-dark-900 border border-dark-700 text-lg font-bold text-white rounded-xl p-4 cursor-pointer outline-none shadow-inner" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].buttonStyle=this.value">
                                        <option value="Primary" ${btn.buttonStyle === 'Primary' ? 'selected' : ''}>أزرق (Primary)</option>
                                        <option value="Success" ${btn.buttonStyle === 'Success' ? 'selected' : ''}>أخضر (Success)</option>
                                        <option value="Danger" ${btn.buttonStyle === 'Danger' ? 'selected' : ''}>أحمر (Danger)</option>
                                        <option value="Secondary" ${btn.buttonStyle === 'Secondary' ? 'selected' : ''}>رمادي (Secondary)</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="flex flex-col md:flex-row items-start md:items-center md:space-x-8 md:space-x-reverse space-y-4 md:space-y-0 text-lg font-black bg-dark-900/60 p-6 rounded-2xl border border-dark-700 mb-8 shadow-inner">
                                <label class="text-emerald-400 flex items-center cursor-pointer w-full md:w-auto">
                                    <input type="checkbox" ${btn.requireModal ? 'checked' : ''} onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].requireModal=this.checked; if(this.checked && !middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields) middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalFields=[]; renderMiddlemanPanels();" class="mr-4 ml-4 w-7 h-7 accent-emerald-400"> 📝 طلب أسئلة منبثقة (Modal) قبل فتح التذكرة
                                </label>
                            </div>
                            
                            <h6 class="text-xl font-black text-amber-400 mb-6 mt-8 border-t border-dark-700 pt-8">🎨 إيمبد تذكرة الوساطة الداخلي الخاص بهذا الزر:</h6>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                <div>
                                    <label class="text-sm font-bold text-slate-400 block mb-3">عنوان الإيمبد الداخلي (Title)</label>
                                    <input type="text" class="w-full bg-dark-900 border border-dark-700 text-base text-white rounded-xl p-4 font-bold focus:border-amber-500 outline-none shadow-inner" value="${btn.insideEmbedTitle || 'تذكرة وساطة'}" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].insideEmbedTitle=this.value">
                                </div>
                                <div>
                                    <label class="text-sm font-bold text-slate-400 block mb-3">وصف الإيمبد الداخلي (يدعم {user})</label>
                                    <input type="text" class="w-full bg-dark-900 border border-dark-700 text-base text-white rounded-xl p-4 focus:border-amber-500 outline-none shadow-inner" value="${btn.insideEmbedDesc || 'أهلاً بك {user}، يرجى انتظار الوسيط'}" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].insideEmbedDesc=this.value">
                                </div>
                                <div class="md:col-span-2 bg-dark-900/40 p-6 rounded-2xl border border-dark-700 shadow-inner mt-4">
                                    <label class="text-base font-black text-amber-400 block mb-4">🎨 لون إيمبد إجابات النافذة المخصص (المربعات - Code Blocks)</label>
                                    <div class="flex items-center space-x-6 space-x-reverse">
                                        <input type="color" class="w-20 h-16 bg-dark-900 rounded-xl p-1.5 cursor-pointer border-2 border-dark-600 shadow-sm" value="${btn.modalAnswersEmbedColor || '#f2a658'}" onchange="middlemanPanelsArray[${pIdx}].buttons[${bIdx}].modalAnswersEmbedColor=this.value">
                                        <input type="text" class="flex-1 bg-dark-900 text-xl font-mono uppercase text-center rounded-xl border border-dark-600 py-4 text-white shadow-inner" value="${btn.modalAnswersEmbedColor || '#f2a658'}" readonly>
                                    </div>
                                </div>
                            </div>
                            ${modalHTML}
                        </div>
                    `;
                });

                container.innerHTML += `
                    <div class="bg-dark-900/80 border-2 border-amber-500/40 rounded-[2.5rem] p-8 md:p-12 relative shadow-[0_15px_50px_rgba(0,0,0,0.6)] mb-14">
                        <button type="button" onclick="middlemanPanelsArray.splice(${pIdx},1); renderMiddlemanPanels();" class="absolute top-8 left-8 md:top-10 md:left-10 bg-red-600 hover:bg-red-500 text-white px-6 py-3 md:py-4 rounded-xl text-sm md:text-lg font-black shadow-lg transition-all transform hover:scale-105 border border-red-400">حذف البانل بالكامل 🗑️</button>
                        
                        <div class="flex flex-col md:flex-row md:items-center space-y-6 md:space-y-0 md:space-x-8 md:space-x-reverse mb-12 border-b-2 border-dark-700 pb-10 mt-12 md:mt-0">
                            <input type="color" class="w-24 h-24 rounded-3xl bg-dark-800 p-2 cursor-pointer border-2 border-dark-600 shadow-inner hidden md:block" value="${panel.panelColor || '#f2a658'}" onchange="middlemanPanelsArray[${pIdx}].panelColor=this.value" title="لون البانل الخارجي">
                            <div class="flex-1 w-full">
                                <label class="text-sm font-bold text-slate-400 block mb-3">عنوان بانل الوساطة الخارجي</label>
                                <input type="text" class="bg-transparent text-4xl md:text-5xl font-black text-white focus:border-b-4 focus:border-amber-500 outline-none w-full md:w-3/4 pb-3 transition-all" value="${panel.panelTitle || ''}" onchange="middlemanPanelsArray[${pIdx}].panelTitle=this.value">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-12">
                            <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 shadow-inner">
                                <label class="text-lg font-bold text-slate-300 block mb-4">روم إرسال البانل</label>
                                <select class="w-full bg-dark-900 text-white font-bold text-xl rounded-2xl p-5 cursor-pointer outline-none border border-dark-700 focus:border-amber-500" onchange="middlemanPanelsArray[${pIdx}].channelId=this.value">
                                    <option value="">-- يرجى اختيار الروم --</option>
                                    ${channelsHTML.replace(`value="${panel.channelId}"`, `value="${panel.channelId}" selected`)}
                                </select>
                            </div>
                            <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 shadow-inner">
                                <label class="text-lg font-bold text-slate-300 block mb-4">قسم فتح تذاكر الوساطة (Category)</label>
                                <select class="w-full bg-dark-900 text-white font-bold text-xl rounded-2xl p-5 cursor-pointer outline-none border border-dark-700 focus:border-amber-500" onchange="middlemanPanelsArray[${pIdx}].categoryId=this.value">
                                    <option value="">-- يرجى اختيار القسم --</option>
                                    ${categoriesHTML.replace(`value="${panel.categoryId}"`, `value="${panel.categoryId}" selected`)}
                                </select>
                            </div>
                            <div class="md:col-span-2 bg-dark-800 p-8 rounded-3xl border border-dark-600 shadow-inner">
                                <label class="text-lg font-bold text-slate-300 block mb-4">وصف بانل الوساطة الخارجي (Description)</label>
                                <textarea class="w-full bg-dark-900 text-white text-xl rounded-2xl p-6 outline-none resize-y border border-dark-700 focus:border-amber-500 leading-relaxed font-bold" rows="3" onchange="middlemanPanelsArray[${pIdx}].panelDescription=this.value">${panel.panelDescription || ''}</textarea>
                            </div>
                        </div>

                        <div class="p-8 md:p-10 bg-dark-900/60 rounded-[2rem] border border-dark-700 shadow-inner">
                            <h4 class="text-3xl md:text-4xl font-black text-amber-400 mb-10">🔘 أزرار بانل الوساطة</h4>
                            ${buttonsHTML}
                            <button type="button" onclick="middlemanPanelsArray[${pIdx}].buttons.push({id:'btn_'+Math.random().toString(36).substr(2,7),label:'طلب وساطة',buttonStyle:'Secondary',requireModal:true,insideEmbedTitle:'تذكرة وساطة',modalAnswersEmbedColor:'#f2a658'}); renderMiddlemanPanels();" class="w-full mt-8 py-6 border-4 border-dashed border-amber-500/40 bg-amber-500/5 hover:bg-amber-500/20 rounded-2xl text-amber-400 font-black text-xl transition-all shadow-md transform hover:-translate-y-1">➕ إضافة زر جديد لهذا البانل</button>
                        </div>
                    </div>
                `;
            });
        }

        function addNewMiddlemanPanelUI() { 
            middlemanPanelsArray.push({
                panelId: 'mm_pnl_' + Math.random().toString(36).substr(2,7), 
                panelTitle: 'تذكرة وساطة آمنة', 
                panelColor: '#f2a658', 
                panelDescription: 'لطلب وسيط معتمد، يرجى الضغط على الزر أدناه وإدخال تفاصيل المعاملة.',
                buttons: []
            });
            renderMiddlemanPanels(); 
        }

        // -----------------------------------------------------------
        // 11. محرك الترجمة الديناميكي للداشبورد (Language Switch)
        // -----------------------------------------------------------
        const systemLang = document.getElementById('system-language');
        function applyDashboardLanguage() {
            const isEnglish = systemLang && systemLang.value === 'en';
            if(isEnglish) {
                document.documentElement.setAttribute('dir', 'ltr');
                document.documentElement.setAttribute('lang', 'en');
                document.body.style.fontFamily = "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif";
                document.querySelectorAll('[data-en]').forEach(el => {
                    if(!el.hasAttribute('data-ar')) el.setAttribute('data-ar', el.innerText);
                    el.innerText = el.getAttribute('data-en');
                });
                document.getElementById('save-btn-text').innerText = "Save Configurations";
            } else {
                document.documentElement.setAttribute('dir', 'rtl');
                document.documentElement.setAttribute('lang', 'ar');
                document.body.style.fontFamily = "'Tajawal', sans-serif";
                document.querySelectorAll('[data-ar]').forEach(el => {
                    el.innerText = el.getAttribute('data-ar');
                });
                document.getElementById('save-btn-text').innerText = "حفظ التعديلات الآن";
            }
            renderWarns(isEnglish ? 'en' : 'ar');
        }
        
        if(systemLang) {
            systemLang.addEventListener('change', applyDashboardLanguage);
            setTimeout(applyDashboardLanguage, 100); 
        }

        // -----------------------------------------------------------
        // 12. تشغيل كل المحركات عند فتح الصفحة تلقائياً (Boot)
        // -----------------------------------------------------------
        window.onload = () => { 
            renderWarns('ar');
            renderWarns('en'); 
            renderAllPanels(); 
            renderMiddlemanPanels(); // محرك بانلات الوساطة الجديد
            renderLvlRewards();
            renderAutoResponders();
            renderCommandRouting(); // محرك توجيه الأوامر الجديد
            
            // إخفاء إشعار (تم الحفظ بنجاح) بعد 5 ثواني
            const alert = document.querySelector('.pop-down-alert');
            if(alert) {
                setTimeout(() => {
                    alert.style.display = 'none';
                }, 5000);
            }
        };
    </script>
</body>
</html>

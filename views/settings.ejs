            autoResponders.forEach((resp, idx) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-4 relative shadow-md group hover:border-fuchsia-500/50 transition-colors">
                        <button type="button" onclick="autoResponders.splice(${idx}, 1); renderAutoResponders();" class="absolute top-4 left-4 text-red-400 bg-red-500/10 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg text-xs font-bold transition-all">حذف 🗑️</button>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-400 mb-2">الكلمة التي يكتبها العضو (Trigger)</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white font-bold focus:border-brand outline-none" placeholder="مثال: السلام عليكم" value="${resp.trigger || ''}" onchange="autoResponders[${idx}].trigger = this.value">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-400 mb-2">رد البوت (نص أو رابط صورة)</label>
                                <input type="text" class="w-full bg-dark-900 border border-dark-700 rounded-xl p-3.5 text-white focus:border-brand outline-none" placeholder="مثال: وعليكم السلام ورحمة الله..." value="${resp.reply || ''}" onchange="autoResponders[${idx}].reply = this.value">
                            </div>
                        </div>
                    </div>
                `;
            });
        }
        function addAutoResponderUI() { autoResponders.push({trigger: 'كلمة جديدة', reply: 'رد جديد'}); renderAutoResponders(); }

        // --- محرك التحذيرات ---
        function renderWarns(lang) {
            const arr = lang === 'ar' ? warnDataAr : warnDataEn;
            const container = document.getElementById(`warn-${lang}-container`);
            container.innerHTML = '';
            arr.forEach((item, index) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-5 rounded-2xl border border-dark-600 mb-4 transition-all shadow-md relative group hover:border-red-500/50">
                        <button type="button" onclick="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}.splice(${index}, 1); renderWarns('${lang}');" class="absolute top-4 left-4 text-red-500 bg-red-500/10 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg text-xs font-bold transition-all opacity-100 md:opacity-0 md:group-hover:opacity-100">حذف 🗑️</button>
                        <label class="block text-sm font-bold text-slate-400 mb-2">السبب (Reason):</label>
                        <input type="text" class="w-full bg-dark-900 border border-dark-700 text-white text-base rounded-xl p-3 font-bold mb-4 focus:border-brand outline-none ${lang === 'en' ? 'text-left' : ''}" dir="${lang === 'en' ? 'ltr' : 'rtl'}" value="${item.reason}" onchange="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}[${index}].reason = this.value">

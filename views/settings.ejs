                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-2" data-en="Ticket Category">قسم التذاكر (Category)</label>
                                <select name="mm_categoryId" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3.5 px-4 text-white font-bold cursor-pointer input-glow">
                                    <option value="" data-en="-- Select Category --">-- اختر القسم --</option>

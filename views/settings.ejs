                                <select class="w-full bg-dark-900 text-white font-bold text-lg rounded-xl p-4 cursor-pointer outline-none border border-dark-700 focus:border-brand" onchange="panelsArray[${pIdx}].categoryId=this.value">
                                    <option value="">-- يرجى اختيار القسم --</option>
                                    ${catsHTML.replace(`value="${panel.categoryId}"`, `value="${panel.categoryId}" selected`)}
                                </select>
                            </div>
                            <div class="md:col-span-2 bg-dark-800 p-6 rounded-2xl border border-dark-600 shadow-inner">
                                <label class="text-base font-bold text-slate-300 block mb-4">وصف البانل الخارجي (Description)</label>
                                <textarea class="w-full bg-dark-900 text-white text-lg rounded-xl p-5 outline-none resize-y border border-dark-700 focus:border-brand leading-relaxed font-bold" rows="3" placeholder="اكتب هنا الوصف الذي سيظهر للأعضاء في الإيمبد الخارجي..." onchange="panelsArray[${pIdx}].panelDescription=this.value">${panel.panelDescription || ''}</textarea>
                            </div>
                        </div>

                        <div class="p-6 md:p-8 bg-dark-900/60 rounded-3xl border border-dark-700 shadow-inner">
                            <h4 class="text-2xl md:text-3xl font-black text-brand-light mb-8">🔘 أزرار البانل</h4>
                            ${buttonsHTML}
                            <button type="button" onclick="panelsArray[${pIdx}].buttons.push({id:'btn_'+Math.random().toString(36).substr(2,7),label:'زر جديد',buttonStyle:'Primary',requireModal:false,insideEmbedTitle:'تذكرة جديدة',modalAnswersEmbedColor:'#2b2d31'}); renderAllPanels();" class="w-full mt-6 py-6 border-4 border-dashed border-brand/40 bg-brand/5 hover:bg-brand/20 rounded-2xl text-brand-light font-black text-lg md:text-xl transition-all shadow-md transform hover:-translate-y-1">➕ إضافة زر جديد لهذا البانل</button>
                        </div>
                    </div>
                `;
            });
        }

        function addNewPanelUI() { 
            panelsArray.push({
                panelId: 'pnl_' + Math.random().toString(36).substr(2,7), 
                panelTitle: 'بانل تذاكر جديد', 
                panelColor: '#5865F2', 
                panelDescription: 'لطلب الدعم الفني يرجى الضغط على الزر أدناه.',
                buttons: []
            });
            renderAllPanels(); 
        }

        // -----------------------------------------------------------
        // 🔄 دالة الحفظ التي لا تقهر (لمنع مسح البيانات نهائياً) 🔄
        // -----------------------------------------------------------
        function submitMegaForm() {
            document.getElementById('warn_reasonsDataAr').value = JSON.stringify(warnDataAr);
            document.getElementById('warn_reasonsDataEn').value = JSON.stringify(warnDataEn);
            document.getElementById('mm_modalFieldsData').value = JSON.stringify(mmFields);
            document.getElementById('ticketPanelsData').value = JSON.stringify(panelsArray);
            document.getElementById('lvl_roleRewardsData').value = JSON.stringify(roleRewards);
            document.getElementById('autoRespondersData').value = JSON.stringify(autoResponders);
            
            const saveBtn = document.querySelector('button[onclick="submitMegaForm()"]');
            saveBtn.innerHTML = '<span class="mr-3 ml-2 text-3xl animate-spin">⏳</span> جاري الحفظ وتحديث السيرفر...';
            saveBtn.classList.replace('bg-emerald-500', 'bg-emerald-700');
            saveBtn.classList.replace('border-emerald-400/50', 'border-emerald-700');
            saveBtn.classList.remove('hover:bg-emerald-400', 'hover:-translate-y-2');
            
            setTimeout(() => {
                document.getElementById('mega-settings-form').submit();
            }, 100);
        }

        // -----------------------------------------------------------
        // 🌍 محرك الترجمة الديناميكي للداشبورد (LRT & RTL)
        // -----------------------------------------------------------
        const systemLang = document.getElementById('system-language');
        function applyDashboardLanguage() {
            const isEnglish = systemLang && systemLang.value === 'en';
            if(isEnglish) {
                document.documentElement.setAttribute('dir', 'ltr');
                document.documentElement.setAttribute('lang', 'en');
                document.body.style.fontFamily = "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif";
                document.querySelectorAll('[data-en]').forEach(el => {
                    if(!el.hasAttribute('data-ar')) el.setAttribute('data-ar', el.innerText);
                    el.innerText = el.getAttribute('data-en');
                });
                document.getElementById('save-btn-text').innerText = "Save Settings Now";
            } else {
                document.documentElement.setAttribute('dir', 'rtl');
                document.documentElement.setAttribute('lang', 'ar');
                document.body.style.fontFamily = "'Tajawal', sans-serif";
                document.querySelectorAll('[data-ar]').forEach(el => {
                    el.innerText = el.getAttribute('data-ar');
                });
                document.getElementById('save-btn-text').innerText = "حفظ التعديلات الآن";
            }
            renderWarns(isEnglish ? 'en' : 'ar');
        }
        
        if(systemLang) {
            systemLang.addEventListener('change', applyDashboardLanguage);
            setTimeout(applyDashboardLanguage, 100); 
        }

        // -----------------------------------------------------------
        // 🚀 تشغيل جميع المحركات عند تحميل الصفحة
        // -----------------------------------------------------------
        window.onload = () => { 
            renderWarns('ar');
            renderWarns('en'); 
            renderMmFields(); 
            renderAllPanels(); 
            renderLvlRewards();
            renderAutoResponders();
            
            // إخفاء إشعار الحفظ بعد 5 ثواني
            const alert = document.querySelector('.pop-down-alert');
            if(alert) {
                setTimeout(() => {
                    alert.style.display = 'none';
                }, 5000);
            }
        };
    </script>
</body>
</html>

                                <div class="md:col-span-2 bg-dark-900/40 p-6 rounded-2xl border border-dark-700 shadow-inner mt-4">
                                    <label class="text-base font-black text-amber-400 block mb-4">🎨 لون إيمبد إجابات النافذة المخصص (المربعات - Code Blocks)</label>
                                    <div class="flex items-center space-x-6 space-x-reverse">
                                        <input type="color" class="w-20 h-16 bg-dark-900 rounded-xl p-1.5 cursor-pointer border-2 border-dark-600 shadow-sm" value="${btn.modalAnswersEmbedColor || '#2b2d31'}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalAnswersEmbedColor=this.value">
                                        <input type="text" class="flex-1 bg-dark-900 text-xl font-mono uppercase text-center rounded-xl border border-dark-600 py-4 text-white shadow-inner" value="${btn.modalAnswersEmbedColor || '#2b2d31'}" readonly>
                                    </div>
                                </div>
                            </div>
                            ${modalHTML}
                        </div>
                    `;
                });

                container.innerHTML += `
                    <div class="bg-dark-900/80 border-2 border-blue-500/40 rounded-[2.5rem] p-8 md:p-12 relative shadow-[0_15px_50px_rgba(0,0,0,0.6)] mb-14">
                        <button type="button" onclick="panelsArray.splice(${pIdx},1); renderAllPanels();" class="absolute top-8 left-8 md:top-10 md:left-10 bg-red-600 hover:bg-red-500 text-white px-6 py-3 md:py-4 rounded-xl text-sm md:text-lg font-black shadow-lg transition-all transform hover:scale-105 border border-red-400">حذف البانل بالكامل 🗑️</button>
                        
                        <div class="flex flex-col md:flex-row md:items-center space-y-6 md:space-y-0 md:space-x-8 md:space-x-reverse mb-12 border-b-2 border-dark-700 pb-10 mt-12 md:mt-0">
                            <input type="color" class="w-24 h-24 rounded-3xl bg-dark-800 p-2 cursor-pointer border-2 border-dark-600 shadow-inner hidden md:block" value="${panel.panelColor || '#5865F2'}" onchange="panelsArray[${pIdx}].panelColor=this.value" title="لون البانل الخارجي">
                            <div class="flex-1 w-full">
                                <label class="text-sm font-bold text-slate-400 block mb-3">عنوان البانل الخارجي (الذي سيظهر في الروم)</label>
                                <input type="text" class="bg-transparent text-4xl md:text-5xl font-black text-white focus:border-b-4 focus:border-brand outline-none w-full md:w-3/4 pb-3 transition-all" value="${panel.panelTitle || ''}" onchange="panelsArray[${pIdx}].panelTitle=this.value">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-12">
                            <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 shadow-inner">
                                <label class="text-lg font-bold text-slate-300 block mb-4">روم إرسال البانل</label>
                                <select class="w-full bg-dark-900 text-white font-bold text-xl rounded-2xl p-5 cursor-pointer outline-none border border-dark-700 focus:border-brand" onchange="panelsArray[${pIdx}].channelId=this.value">
                                    <option value="">-- يرجى اختيار الروم --</option>
                                    ${channelsHTML.replace(`value="${panel.channelId}"`, `value="${panel.channelId}" selected`)}
                                </select>
                            </div>
                            <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 shadow-inner">
                                <label class="text-lg font-bold text-slate-300 block mb-4">قسم فتح التذاكر (Category)</label>
                                <select class="w-full bg-dark-900 text-white font-bold text-xl rounded-2xl p-5 cursor-pointer outline-none border border-dark-700 focus:border-brand" onchange="panelsArray[${pIdx}].categoryId=this.value">
                                    <option value="">-- يرجى اختيار القسم --</option>
                                    ${categoriesHTML.replace(`value="${panel.categoryId}"`, `value="${panel.categoryId}" selected`)}

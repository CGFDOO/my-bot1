    <script>
        function toggleMobileSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar.classList.contains('translate-x-full')) {
                sidebar.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        function switchSection(target) {
            document.querySelectorAll('.settings-section').forEach(s => s.classList.remove('active'));
            document.getElementById('section-' + target).classList.add('active');
            document.querySelectorAll('.nav-btn').forEach(b => { 
                b.classList.remove('bg-brand','text-white'); 
                b.classList.add('text-slate-400'); 
            });
            const activeBtn = document.querySelector(`[data-target="${target}"]`);
            if(activeBtn) { 
                activeBtn.classList.add('bg-brand','text-white');
                activeBtn.classList.remove('text-slate-400'); 
            }
            if(window.innerWidth < 768) toggleMobileSidebar();
        }

        const safeConfig = <%- JSON.stringify(config || {}) %>;
        let panelsArray = safeConfig.ticketPanels || [];
        let mmFields = safeConfig.middlemanSystem?.modalFields || [];
        let roleRewards = safeConfig.leveling?.roleRewards || [];
        let autoResponders = safeConfig.autoResponders || [];
        let warnDataAr = safeConfig.warnings?.reasonsDataAr || [{"reason": "سب وشتم", "dmMessage": "لقد تم تحذيرك بسبب السب والشتم. يرجى احترام القوانين."}];
        let warnDataEn = safeConfig.warnings?.reasonsDataEn || [{"reason": "Swearing", "dmMessage": "You have been warned for swearing."}];

        function renderWarns(lang) {
            const arr = lang === 'ar' ? warnDataAr : warnDataEn;
            const container = document.getElementById(`warn-${lang}-container`);
            if(!container) return;
            container.innerHTML = '';
            arr.forEach((item, index) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-5 rounded-2xl border border-dark-600 mb-4 transition-all shadow-md relative group hover:border-red-500/50">
                        <button type="button" onclick="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}.splice(${index}, 1); renderWarns('${lang}');" class="absolute top-4 left-4 text-red-500 bg-red-500/10 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg text-xs font-bold transition-all opacity-100 md:opacity-0 md:group-hover:opacity-100">حذف 🗑️</button>
                        <label class="block text-sm font-bold text-slate-400 mb-2">السبب (Reason):</label>
                        <input type="text" class="w-full bg-dark-900 border border-dark-700 text-white text-base rounded-xl p-3 font-bold mb-4 focus:border-brand outline-none" dir="${lang === 'en' ? 'ltr' : 'rtl'}" value="${item.reason}" onchange="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}[${index}].reason = this.value">
                        <label class="block text-sm font-bold text-brand-light mb-2">رسالة الخاص للعضو (DM Message):</label>
                        <textarea class="w-full bg-dark-900 border border-dark-700 text-white text-sm rounded-xl p-4 resize-y focus:border-brand outline-none" dir="${lang === 'en' ? 'ltr' : 'rtl'}" rows="3" onchange="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}[${index}].dmMessage = this.value">${item.dmMessage}</textarea>
                    </div>
                `;
            });
        }
        function addWarnReason(lang) { 
            if(lang === 'ar') warnDataAr.push({reason: 'سبب جديد', dmMessage: 'لقد تم تحذيرك بسبب...'}); 
            else warnDataEn.push({reason: 'New Reason', dmMessage: 'You have been warned for...'}); 
            renderWarns(lang); 
        }

        const sRolesHTML = `<%- serverRoles.map(r => `<option value="${r.id}">${r.name}</option>`).join('') %>`;
        function renderLvlRewards() {
            const container = document.getElementById('level-rewards-container');
            if(!container) return;
            container.innerHTML = '';
            if(roleRewards.length === 0){ container.innerHTML = '<div class="text-center text-slate-500 text-base p-8 border-2 border-dashed border-dark-600 rounded-2xl font-bold">لا يوجد جوائز رتب.</div>'; return; }
            roleRewards.forEach((reward, index) => {
                container.innerHTML += `
                    <div class="flex flex-col md:flex-row items-center space-x-0 md:space-x-6 md:space-x-reverse space-y-4 md:space-y-0 bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-3 shadow-lg hover:border-blue-500/50">
                        <div class="flex items-center w-full md:w-auto">
                            <span class="text-brand-light font-black text-base w-40">عند الوصول لـ لفل:</span>
                            <input type="number" min="1" class="w-24 bg-dark-900 border border-dark-600 rounded-xl py-3 px-3 text-white font-black text-center text-xl outline-none" value="${reward.levelRequired}" onchange="roleRewards[${index}].levelRequired = parseInt(this.value)">
                        </div>
                        <div class="flex items-center w-full md:flex-1">
                            <span class="text-slate-400 font-bold text-base w-24">يأخذ رتبة:</span>
                            <select class="flex-1 bg-dark-900 border border-dark-600 rounded-xl py-3 px-4 text-white font-bold cursor-pointer outline-none" onchange="roleRewards[${index}].roleId = this.value">
                                <option value="">-- يرجى اختيار الرتبة --</option>
                                ${sRolesHTML.replace(`value="${reward.roleId}"`, `value="${reward.roleId}" selected`)}
                            </select>
                        </div>
                        <div class="flex items-center w-full md:w-auto">
                            <span class="text-slate-400 font-bold text-base w-32">عدد الرسائل تقريباً:</span>
                            <input type="text" class="w-24 bg-dark-900 border border-dark-600 rounded-xl py-3 px-3 text-slate-500 font-bold text-center outline-none" value="${reward.levelRequired * 100}" disabled>
                        </div>
                        <button type="button" onclick="roleRewards.splice(${index}, 1); renderLvlRewards();" class="w-full md:w-auto bg-red-600 text-white px-8 py-3 rounded-xl font-black">إزالة 🗑️</button>
                    </div>
                `;
            });
        }
        function addLevelRewardUI() { roleRewards.push({ levelRequired: 5, roleId: '' }); renderLvlRewards(); }

        function submitMegaForm() {
            document.getElementById('warn_reasonsDataAr').value = JSON.stringify(warnDataAr);
            document.getElementById('warn_reasonsDataEn').value = JSON.stringify(warnDataEn);
            document.getElementById('lvl_roleRewardsData').value = JSON.stringify(roleRewards);
            
            const saveBtn = document.querySelector('button[onclick="submitMegaForm()"]');
            saveBtn.innerHTML = '<span class="mr-3 ml-2 text-3xl animate-spin">⏳</span> جاري الحفظ وتحديث السيرفر...';
            saveBtn.classList.replace('bg-emerald-500', 'bg-emerald-700');
            setTimeout(() => { document.getElementById('mega-settings-form').submit(); }, 100);
        }

        window.onload = () => { 
            renderWarns('ar'); renderWarns('en'); renderLvlRewards();
        };
    </script>
</body>
</html>

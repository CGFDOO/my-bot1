                                        <input type="text" id="warn_panelColor" name="warn_panelColor" value="<%= config.warnings?.panelColor || '#ed4245' %>" class="flex-1 bg-dark-800 border border-dark-600 rounded-xl py-4 px-4 text-white font-mono uppercase text-center input-glow text-lg">

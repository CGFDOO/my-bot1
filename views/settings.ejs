<script>
        
        // -----------------------------------------------------------
        // 1. المتغيرات السحابية الأساسية للحفظ (Variables)
        // -----------------------------------------------------------
        const safeConfig = <%- JSON.stringify(config || {}) %>;
        
        let warnDataAr = safeConfig.warnings?.reasonsDataAr || [];
        let warnDataEn = safeConfig.warnings?.reasonsDataEn || [];
        
        // بانلات التذاكر العادية
        let panelsArray = safeConfig.ticketPanels || [];
        
        // بانلات الوساطة المتعددة (الجديدة كلياً)
        let middlemanPanelsArray = safeConfig.middlemanSystem?.panels || [];
        
        let roleRewards = safeConfig.leveling?.roleRewards || [];
        let autoResponders = safeConfig.autoResponders || [];
        
        // نظام توجيه الأوامر المتقدم (Command Routing)
        let commandRouting = safeConfig.commandRouting || []; 

        const serverRolesHTML = `<%- serverRoles.map(r => `<option value="${r.id}">${r.name}</option>`).join('') %>`;
        const categoriesHTML = `<%- categories.map(cat => `<option value="${cat.id}">${cat.name}</option>`).join('') %>`;
        const channelsHTML = `<%- textChannels.map(ch => `<option value="${ch.id}">${ch.name}</option>`).join('') %>`;
        const textChannelsArr = <%- JSON.stringify(textChannels) %>;

        // -----------------------------------------------------------
        // 2. دالة الحفظ العملاقة التي ترسل الداتا للداتابيز بأمان تام
        // -----------------------------------------------------------
        function setSecureHiddenData(id, name, data) {
            let el = document.getElementById(id);
            if (!el) {
                el = document.createElement('input');
                el.type = 'hidden';
                el.id = id;
                el.name = name;
                document.getElementById('mega-settings-form').appendChild(el);
            }
            el.value = JSON.stringify(data);
        }

        function submitMegaForm() {
            // استخدام الطريقة الآمنة لتعبئة كل المصفوفات قبل الإرسال
            setSecureHiddenData('warn_reasonsDataAr', 'warn_reasonsDataAr', warnDataAr);
            setSecureHiddenData('warn_reasonsDataEn', 'warn_reasonsDataEn', warnDataEn);
            setSecureHiddenData('ticketPanelsData', 'ticketPanelsData', panelsArray);
            setSecureHiddenData('mm_panelsData', 'mm_panelsData', middlemanPanelsArray); // حفظ بانلات الوساطة المتعددة
            setSecureHiddenData('lvl_roleRewardsData', 'lvl_roleRewardsData', roleRewards);
            setSecureHiddenData('autoRespondersData', 'autoRespondersData', autoResponders);
            setSecureHiddenData('cmd_routingData', 'cmd_routingData', commandRouting); // حفظ توجيه الأوامر
            
            // تغيير شكل زر الحفظ ليعطي تأثير التحميل
            const saveBtn = document.querySelector('button[onclick="submitMegaForm()"]');
            const isEnglish = document.getElementById('system-language')?.value === 'en';
            
            saveBtn.innerHTML = `<span class="mr-3 ml-2 text-3xl animate-spin">⏳</span> ${isEnglish ? 'Saving Configuration...' : 'جاري الحفظ وتحديث السيرفر...'}`;
            saveBtn.classList.replace('bg-emerald-500', 'bg-emerald-700');
            saveBtn.classList.replace('border-emerald-400/50', 'border-emerald-700');
            saveBtn.classList.remove('hover:bg-emerald-400', 'hover:-translate-y-2');
            
            // إرسال الفورم بعد التأكد من التعبئة التامة
            setTimeout(() => {
                document.getElementById('mega-settings-form').submit();
            }, 150);
        }

        // -----------------------------------------------------------
        // 3. دوال التنقل والقائمة الجانبية
        // -----------------------------------------------------------
        function toggleMobileSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            
            if (sidebar.classList.contains('translate-x-full')) {
                sidebar.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        function switchSection(target) {
            document.querySelectorAll('.settings-section').forEach(section => {
                section.classList.remove('active');
            });
            
            const targetSection = document.getElementById('section-' + target);
            if(targetSection) targetSection.classList.add('active');
            
            document.querySelectorAll('.nav-btn').forEach(btn => { 
                btn.classList.remove('bg-brand', 'text-white', 'active-nav'); 
                btn.classList.add('text-slate-400'); 
            });
            
            const activeBtn = document.querySelector(`[data-target="${target}"]`);
            if(activeBtn) { 
                activeBtn.classList.add('bg-brand', 'text-white', 'active-nav');
                activeBtn.classList.remove('text-slate-400'); 
            }
            
            document.getElementById('main-scroll-area').scrollTo({ top: 0, behavior: 'smooth' });
            
            if(window.innerWidth < 768) {
                toggleMobileSidebar();
            }
        }

        // -----------------------------------------------------------
        // 4. دالة إنشاء الإيمبد المباشر (Live Embed)
        // -----------------------------------------------------------
        async function sendLiveEmbed(guildId) {
            const channelId = document.getElementById('live_embed_channel').value;
            const title = document.getElementById('live_embed_title').value;
            const description = document.getElementById('live_embed_desc').value;
            const color = document.getElementById('live_embed_color').value;
            const imageUrl = document.getElementById('live_embed_image').value;
            const statusDiv = document.getElementById('live_embed_status');
            
            if(!channelId || (!title && !description)) { 
                statusDiv.className = 'mb-6 p-4 rounded-xl bg-red-500/20 text-red-400 border border-red-500 font-bold';
                statusDiv.innerText = '❌ يرجى اختيار الروم وكتابة محتوى الإيمبد أولاً.'; 
                statusDiv.classList.remove('hidden'); 
                return;
            }
            
            statusDiv.className = 'mb-6 p-4 rounded-xl bg-blue-500/20 text-blue-400 border border-blue-500 font-bold';
            statusDiv.innerText = '⏳ جاري الإرسال للديسكورد...'; 
            statusDiv.classList.remove('hidden');
            
            try {
                const res = await fetch(`/api/send-embed/${guildId}`, { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ channelId, title, description, color, imageUrl }) 
                });
                const data = await res.json();
                
                if(data.success) { 
                    statusDiv.className = 'mb-6 p-4 rounded-xl bg-emerald-500/20 text-emerald-400 border border-emerald-500 font-bold';
                    statusDiv.innerText = '✅ تم الإرسال بنجاح إلى الروم!'; 
                    document.getElementById('live_embed_title').value = ''; 
                    document.getElementById('live_embed_desc').value = ''; 
                    document.getElementById('live_embed_image').value = '';
                } else { 
                    statusDiv.className = 'mb-6 p-4 rounded-xl bg-red-500/20 text-red-400 border border-red-500 font-bold';
                    statusDiv.innerText = data.error || '❌ فشل الإرسال.'; 
                }
            } catch(e) { 
                statusDiv.className = 'mb-6 p-4 rounded-xl bg-red-500/20 text-red-400 border border-red-500 font-bold';
                statusDiv.innerText = '❌ حدث خطأ في الاتصال بالبوت. تأكد من أن البوت يعمل.'; 
            }
        }


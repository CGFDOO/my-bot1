                                <input type="text" name="mm_panelTitle" value="<%= config.middlemanSystem?.panelTitle || 'تذكرة وساطة آمنة' %>" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3 px-4 text-white font-bold input-glow">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-2" data-en="Outer Panel Color">لون الإيمبد الخارجي</label>

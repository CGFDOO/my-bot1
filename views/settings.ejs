            </button>
            <button onclick="switchSection('custom_panels')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="custom_panels">
                <span class="text-lg">🎫</span> <span data-en="Dynamic Panels">البانلات الديناميكية</span>
            </button>
            <button onclick="switchSection('ticket_controls')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="ticket_controls">
                <span class="text-lg">🛠️</span> <span data-en="Ticket Controls">التحكم الداخلي للتكت</span>
            </button>

            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 mt-8 px-2" data-en="Management">الإدارة والعقوبات</div>
            <button onclick="switchSection('system_points')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-orange-400 hover:bg-dark-700 font-bold" data-target="system_points">
                <span class="text-lg">🎯</span> <span data-en="System Points">السيستم بوينت الشامل</span>
            </button>
            <button onclick="switchSection('warnings')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="warnings">
                <span class="text-lg">⚠️</span> <span data-en="Warnings Panel">نظام التحذيرات وبانل الإدارة</span>
            </button>
            <button onclick="switchSection('commands')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="commands">
                <span class="text-lg">⌨️</span> <span data-en="Custom Commands">الأوامر المتعددة (Aliases)</span>
            </button>
            <button onclick="switchSection('command_routing')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-cyan-400 hover:bg-dark-700 font-bold" data-target="command_routing">
                <span class="text-lg">🧭</span> <span data-en="Command Routing">توجيه الأوامر والرومات</span>
            </button>
            <button onclick="switchSection('custom_embeds')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-fuchsia-400 hover:bg-dark-700 font-bold" data-target="custom_embeds">
                <span class="text-lg">🎨</span> <span data-en="Custom Embeds">الإيمبدات (Basic/Editable)</span>
            </button>

            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 mt-8 px-2" data-en="Logs & Auto">السجلات والردود</div>
            <button onclick="switchSection('auto_responders')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="auto_responders">
                <span class="text-lg">💬</span> <span data-en="Auto Responders & Line">الردود التلقائية والخط</span>
            </button>
            <button onclick="switchSection('logs')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="logs">
                <span class="text-lg">📝</span> <span data-en="Server Logs">السجلات الشاملة (الروابط والكيك)</span>
            </button>
            <button onclick="switchSection('roles')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="roles">
                <span class="text-lg">👑</span> <span data-en="Roles & Permissions">الرتب والصلاحيات العليا</span>
            </button>
            <button onclick="switchSection('ratings')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="ratings">
                <span class="text-lg">⭐</span> <span data-en="Ratings">التقييمات المزدوجة</span>
            </button>

            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 mt-8 px-2" data-en="Protection & Features">الحماية والأنظمة</div>
            <button onclick="switchSection('protection')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="protection">
                <span class="text-lg">🛡️</span> <span data-en="Anti-Nuke">الحماية والـ Anti-Nuke</span>
            </button>
            <button onclick="switchSection('welcome')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="welcome">
                <span class="text-lg">👋</span> <span data-en="Welcome & Leave">الترحيب المتطور والمغادرة</span>
            </button>
            <button onclick="switchSection('invites')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-emerald-400 hover:bg-dark-700 font-bold" data-target="invites">
                <span class="text-lg">📨</span> <span data-en="Invites Tracker">نظام الدعوات (Fake/Left)</span>

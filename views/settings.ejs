                                </div>
                        `;
                        (btn.modalFields || []).forEach((mf, mIdx) => {
                            modalHTML += `
                                <div class="flex flex-col space-y-4 mb-5 bg-dark-800 p-5 rounded-2xl border border-dark-600 relative">
                                    <button type="button" onclick="panelsArray[${pIdx}].buttons[${bIdx}].modalFields.splice(${mIdx},1); renderAllPanels();" class="absolute top-4 left-4 bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-bold transition-all shadow-sm text-xs">حذف</button>
                                    <div class="flex flex-col md:flex-row gap-4 mt-4">
                                        <input type="text" class="w-full md:w-1/2 bg-dark-900 border border-dark-700 text-sm text-white rounded-xl p-3.5 font-bold focus:border-brand outline-none" placeholder="السؤال الذي سيظهر للعميل" value="${mf.label}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].label=this.value">
                                        <input type="text" class="w-full md:w-1/2 bg-dark-900 border border-dark-700 text-sm text-white rounded-xl p-3.5 focus:border-brand outline-none" placeholder="مثال إرشادي للإجابة (اختياري)" value="${mf.placeholder}" onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].placeholder=this.value">
                                    </div>
                                    <div class="flex flex-col space-y-3 bg-dark-900/50 p-4 rounded-xl border border-dark-700 w-full md:w-1/2">
                                        <label class="cursor-pointer flex items-center text-sm font-bold text-brand-light">
                                            <input type="radio" name="p_${pIdx}_b_${bIdx}_m_${mIdx}" value="Short" class="mr-3 ml-3 w-5 h-5 accent-brand" ${mf.style !== 'Paragraph' ? 'checked' : ''} onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].style=this.value"> إجابة قصيرة (سطر واحد)
                                        </label>
                                        <label class="cursor-pointer flex items-center text-sm font-bold text-brand-light">
                                            <input type="radio" name="p_${pIdx}_b_${bIdx}_m_${mIdx}" value="Paragraph" class="mr-3 ml-3 w-5 h-5 accent-brand" ${mf.style === 'Paragraph' ? 'checked' : ''} onchange="panelsArray[${pIdx}].buttons[${bIdx}].modalFields[${mIdx}].style=this.value"> إجابة طويلة (فقرة كبيرة)
                                        </label>
                                    </div>
                                </div>
                            `;
                        });
                        modalHTML += `</div>`;
                    }

                    buttonsHTML += `
                        <div class="bg-dark-800 p-8 rounded-3xl border border-dark-600 mb-8 relative shadow-xl">
                            <button type="button" onclick="panelsArray[${pIdx}].buttons.splice(${bIdx},1); renderAllPanels();" class="absolute top-5 left-5 text-red-400 bg-red-500/10 hover:bg-red-500 hover:text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all">حذف هذا الزر 🗑️</button>
                            <h5 class="text-xl font-black text-white mb-8 border-b border-dark-700 pb-4">🔘 إعدادات الزر رقم ${bIdx + 1}</h5>
                            

                                <select name="log_messageDeleteLogId" class="w-full bg-dark-800 border border-dark-600 text-xs text-white rounded-xl p-3 cursor-pointer input-glow"><option value="">- معطل -</option><%- textChannels.map(c=>`<option value="${c.id}" ${config.serverLogs?.messageDeleteLogId===c.id?'selected':''}>💬 ${c.name}</option>`).join('') %></select>

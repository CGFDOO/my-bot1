                        <input type="text" id="live_embed_title" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3 px-4 text-white input-glow font-bold text-lg mb-6" placeholder="اكتب عنوان الإيمبد...">
                        
                        <label class="block text-sm font-bold text-slate-300 mb-2" data-en="Description">الوصف / القوانين (يدعم الزخارف)</label>
                        <textarea id="live_embed_desc" rows="6" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-4 px-5 text-white input-glow resize-y mb-6" placeholder="اكتب محتوى الإيمبد هنا..."></textarea>
                        
                        <label class="block text-sm font-bold text-slate-300 mb-2" data-en="Image URL (Optional)">رابط صورة (اختياري)</label>
                        <input type="text" id="live_embed_image" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3 px-4 text-white input-glow text-left font-mono mb-8" dir="ltr" placeholder="https://...">
                        

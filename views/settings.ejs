    </main>

    <script>
        // المتغيرات السحابية
        const serverRoles = <%- JSON.stringify(serverRoles) %>;
        let warnReasonsAr = <%- JSON.stringify(config.warnings?.reasonsDataAr || []) %>;
        let warnReasonsEn = <%- JSON.stringify(config.warnings?.reasonsDataEn || []) %>;
        let mmFields = <%- JSON.stringify(config.middlemanSystem?.modalFields || []) %>;
        let ticketPanels = <%- JSON.stringify(config.ticketPanels || []) %>;
        let lvlRewards = <%- JSON.stringify(config.leveling?.roleRewards || []) %>;
        let autoResponders = <%- JSON.stringify(config.autoResponders || []) %>;
        let isEnglish = '<%= config.language %>' === 'en';

        // -----------------------------------------------------------\n        // 🎯 المحرك الرئيسي للإرسال والحفظ
        // -----------------------------------------------------------\n        function submitMegaForm() {
            const btnText = document.getElementById('save-btn-text');
            const originalText = btnText.innerText;
            btnText.innerText = isEnglish ? "Saving..." : "جاري الحفظ...";
            
            // تجميع الداتا المعقدة في الحقول المخفية
            document.getElementById('warn_reasonsDataAr').value = JSON.stringify(warnReasonsAr);
            document.getElementById('warn_reasonsDataEn').value = JSON.stringify(warnReasonsEn);
            document.getElementById('mm_modalFieldsData').value = JSON.stringify(mmFields);
            document.getElementById('ticketPanelsData').value = JSON.stringify(ticketPanels);
            document.getElementById('lvl_roleRewardsData').value = JSON.stringify(lvlRewards);
            document.getElementById('autoRespondersData').value = JSON.stringify(autoResponders);
            
            // إرسال الفورم
            document.getElementById('mega-settings-form').submit();
        }

        // -----------------------------------------------------------\n        // 🚀 التنقل بين الأقسام
        // -----------------------------------------------------------\n        function switchSection(sectionId) {
            document.querySelectorAll('.settings-section').forEach(sec => sec.classList.remove('active'));
            document.getElementById(`section-${sectionId}`).classList.add('active');
            
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('bg-brand', 'text-white', 'active-nav');
                btn.classList.add('text-slate-400');
            });
            const clickedBtn = document.querySelector(`[data-target="${sectionId}"]`);
            if (clickedBtn) {
                clickedBtn.classList.remove('text-slate-400');
                clickedBtn.classList.add('bg-brand', 'text-white', 'active-nav');
            }
            
            document.getElementById('main-scroll-area').scrollTo({ top: 0, behavior: 'smooth' });
            if (window.innerWidth < 768) toggleMobileSidebar();
        }

        function toggleMobileSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            sidebar.classList.toggle('translate-x-full');
            overlay.classList.toggle('hidden');
        }

        // -----------------------------------------------------------\n        // ⚙️ نظام التحذيرات
        // -----------------------------------------------------------\n        function renderWarns(lang) {
            const container = document.getElementById(`warn-${lang}-container`);
            if(!container) return;
            const data = lang === 'ar' ? warnReasonsAr : warnReasonsEn;
            container.innerHTML = '';
            
            data.forEach((r, idx) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-4 rounded-xl border border-dark-600 flex flex-col space-y-3 relative">
                        <button type="button" onclick="removeWarnReason('${lang}', ${idx})" class="absolute top-2 left-2 text-red-500 hover:text-red-400">❌</button>
                        <input type="text" value="${r.reason}" onchange="updateWarnReason('${lang}', ${idx}, 'reason', this.value)" placeholder="${lang === 'ar' ? 'السبب (مثال: سب وشتم)' : 'Reason'}" class="w-full bg-dark-900 border border-dark-700 p-2 rounded-lg text-white text-sm font-bold">
                        <textarea rows="2" onchange="updateWarnReason('${lang}', ${idx}, 'message', this.value)" placeholder="${lang === 'ar' ? 'رسالة الخاص (DM) للعضو' : 'DM Message'}" class="w-full bg-dark-900 border border-dark-700 p-2 rounded-lg text-white text-xs">${r.message}</textarea>
                    </div>`;
            });
        }
        function addWarnReason(lang) {
            const data = lang === 'ar' ? warnReasonsAr : warnReasonsEn;
            data.push({ reason: '', message: '' });
            renderWarns(lang);
        }
        function updateWarnReason(lang, idx, field, val) {
            const data = lang === 'ar' ? warnReasonsAr : warnReasonsEn;
            data[idx][field] = val;
        }
        function removeWarnReason(lang, idx) {
            const data = lang === 'ar' ? warnReasonsAr : warnReasonsEn;
            data.splice(idx, 1);
            renderWarns(lang);
        }

        // -----------------------------------------------------------\n        // ⚙️ نظام البانلات والنافذة
        // -----------------------------------------------------------\n        function renderMmFields() {
            const c = document.getElementById('mm-fields-ui-container');
            if(!c) return;
            c.innerHTML = mmFields.map((f, i) => `
                <div class="flex items-center space-x-2 space-x-reverse bg-dark-800 p-3 rounded-xl border border-dark-600">
                    <input type="text" value="${f.label}" onchange="mmFields[${i}].label=this.value" placeholder="السؤال" class="flex-1 bg-dark-900 border border-dark-700 p-2 rounded-lg text-white text-sm font-bold">
                    <select onchange="mmFields[${i}].style=this.value" class="bg-dark-900 border border-dark-700 p-2 rounded-lg text-white text-sm">
                        <option value="Short" ${f.style==='Short'?'selected':''}>إجابة قصيرة</option>
                        <option value="Paragraph" ${f.style==='Paragraph'?'selected':''}>إجابة طويلة</option>
                    </select>
                    <label class="flex items-center text-sm"><input type="checkbox" ${f.required?'checked':''} onchange="mmFields[${i}].required=this.checked" class="mr-1 ml-1"> إجباري</label>
                    <button type="button" onclick="mmFields.splice(${i},1); renderMmFields()" class="text-red-500 font-bold p-2 bg-dark-900 rounded-lg">X</button>
                </div>
            `).join('');
        }
        function addMmFieldUI() { mmFields.push({ label: 'سؤال جديد', style: 'Short', placeholder: '', required: true }); renderMmFields(); }

        function renderAllPanels() {
            const mainCont = document.getElementById('dynamic-panels-container');
            if(!mainCont) return;
            mainCont.innerHTML = ticketPanels.map((p, pIndex) => `
                <div class="bg-dark-900/80 p-6 rounded-2xl border border-blue-500/30 mb-6 relative shadow-inner">
                    <button type="button" onclick="ticketPanels.splice(${pIndex}, 1); renderAllPanels()" class="absolute top-4 left-4 text-red-500 bg-dark-800 p-2 rounded-lg font-bold">🗑️ مسح البانل</button>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 mt-2">
                        <div><label class="text-xs font-bold text-slate-400">قسم التذاكر (Category)</label>
                        <select onchange="ticketPanels[${pIndex}].categoryId=this.value" class="w-full bg-dark-800 border border-dark-600 p-3 rounded-xl text-white mt-1"><option value="">-- اختر --</option><%- categories.map(c=>`<option value="${c.id}">${c.name}</option>`).join('') %></select></div>
                        <div><label class="text-xs font-bold text-slate-400">روم إرسال البانل</label>
                        <select onchange="ticketPanels[${pIndex}].panelChannelId=this.value" class="w-full bg-dark-800 border border-dark-600 p-3 rounded-xl text-white mt-1"><option value="">-- اختر --</option><%- textChannels.map(c=>`<option value="${c.id}">${c.name}</option>`).join('') %></select></div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <input type="text" value="${p.panelTitle||''}" onchange="ticketPanels[${pIndex}].panelTitle=this.value" placeholder="عنوان الإيمبد" class="w-full bg-dark-800 border border-dark-600 p-3 rounded-xl text-white font-bold">
                        <input type="color" value="${p.panelColor||'#5865F2'}" onchange="ticketPanels[${pIndex}].panelColor=this.value" class="w-full h-12 rounded-xl bg-dark-800 p-1">
                    </div>
                    <textarea onchange="ticketPanels[${pIndex}].panelDescription=this.value" placeholder="وصف الإيمبد" class="w-full bg-dark-800 border border-dark-600 p-3 rounded-xl text-white mb-4">${p.panelDescription||''}</textarea>
                    
                    <div class="bg-dark-800 p-4 rounded-xl border border-dark-600">
                        <h4 class="font-bold text-white mb-3">أزرار البانل</h4>
                        ${(p.buttons||[]).map((btn, bIndex) => `
                            <div class="flex items-center space-x-2 space-x-reverse mb-2 bg-dark-900 p-2 rounded-lg">
                                <input type="text" value="${btn.label}" onchange="ticketPanels[${pIndex}].buttons[${bIndex}].label=this.value" class="w-1/3 bg-dark-800 border border-dark-600 p-2 rounded text-white text-sm" placeholder="اسم الزر">
                                <select onchange="ticketPanels[${pIndex}].buttons[${bIndex}].style=this.value" class="w-1/3 bg-dark-800 border border-dark-600 p-2 rounded text-white text-sm"><option value="Primary" ${btn.style==='Primary'?'selected':''}>أزرق</option><option value="Success" ${btn.style==='Success'?'selected':''}>أخضر</option><option value="Danger" ${btn.style==='Danger'?'selected':''}>أحمر</option><option value="Secondary" ${btn.style==='Secondary'?'selected':''}>رصاصي</option></select>
                                <button type="button" onclick="ticketPanels[${pIndex}].buttons.splice(${bIndex}, 1); renderAllPanels()" class="text-red-500 font-bold p-2">X</button>
                            </div>
                        `).join('')}
                        <button type="button" onclick="if(!ticketPanels[${pIndex}].buttons) ticketPanels[${pIndex}].buttons=[]; ticketPanels[${pIndex}].buttons.push({id: 'btn_'+Date.now(), label: 'زر جديد', style: 'Primary', requireModal: false}); renderAllPanels()" class="text-blue-400 font-bold text-sm mt-2">➕ إضافة زر</button>
                    </div>
                </div>
            `).join('');
            
            // تحديد الـ selects
            ticketPanels.forEach((p, pI) => {
                const cats = document.querySelectorAll(`select[onchange="ticketPanels[${pI}].categoryId=this.value"] option`);
                cats.forEach(o => { if(o.value === p.categoryId) o.selected = true; });
                const chans = document.querySelectorAll(`select[onchange="ticketPanels[${pI}].panelChannelId=this.value"] option`);
                chans.forEach(o => { if(o.value === p.panelChannelId) o.selected = true; });
            });
        }
        function addNewPanelUI() { ticketPanels.push({ id: 'panel_'+Date.now(), categoryId: '', panelChannelId: '', panelTitle: 'بانل جديد', panelColor: '#5865F2', panelDescription: '', buttons: [] }); renderAllPanels(); }

        // -----------------------------------------------------------\n        // ⚙️ نظام اللفلات والردود
        // -----------------------------------------------------------\n        function renderLvlRewards() {
            const c = document.getElementById('lvl-rewards-container');
            if(!c) return;
            c.innerHTML = lvlRewards.map((r, i) => `
                <div class="flex items-center space-x-2 space-x-reverse bg-dark-800 p-3 rounded-xl border border-dark-600">
                    <span class="text-white font-bold">لفل:</span>
                    <input type="number" value="${r.level}" onchange="lvlRewards[${i}].level=parseInt(this.value)" class="w-20 bg-dark-900 border border-dark-700 p-2 rounded-lg text-white font-bold text-center">
                    <span class="text-white font-bold">الرتبة:</span>
                    <select onchange="lvlRewards[${i}].roleId=this.value" class="flex-1 bg-dark-900 border border-dark-700 p-2 rounded-lg text-white font-bold"><option value="">- اختر -</option><%- serverRoles.map(ro=>`<option value="${ro.id}">${ro.name}</option>`).join('') %></select>
                    <button type="button" onclick="lvlRewards.splice(${i},1); renderLvlRewards()" class="text-red-500 font-bold p-2 bg-dark-900 rounded-lg">X</button>
                </div>
            `).join('');
            lvlRewards.forEach((r, i) => {
                const opts = document.querySelectorAll(`select[onchange="lvlRewards[${i}].roleId=this.value"] option`);
                opts.forEach(o => { if(o.value === r.roleId) o.selected = true; });
            });
        }
        function addLvlRewardUI() { lvlRewards.push({ level: 10, roleId: '' }); renderLvlRewards(); }

        function renderAutoResponders() {
            const c = document.getElementById('auto-responders-container');
            if(!c) return;
            c.innerHTML = autoResponders.map((r, i) => `
                <div class="flex flex-col md:flex-row items-center space-y-2 md:space-y-0 md:space-x-2 md:space-x-reverse bg-dark-800 p-3 rounded-xl border border-dark-600 relative">
                    <button type="button" onclick="autoResponders.splice(${i},1); renderAutoResponders()" class="absolute md:relative top-2 left-2 md:top-auto md:left-auto text-red-500 font-bold p-2">X</button>
                    <input type="text" value="${r.trigger}" onchange="autoResponders[${i}].trigger=this.value" placeholder="الكلمة" class="w-full md:w-1/3 bg-dark-900 border border-dark-700 p-3 rounded-lg text-white font-bold input-glow">
                    <input type="text" value="${r.reply}" onchange="autoResponders[${i}].reply=this.value" placeholder="الرد" class="w-full md:flex-1 bg-dark-900 border border-dark-700 p-3 rounded-lg text-white font-bold input-glow">
                </div>
            `).join('');
        }
        function addAutoResponderUI() { autoResponders.push({ trigger: '', reply: '' }); renderAutoResponders(); }

        // -----------------------------------------------------------\n        // ⚙️ تغيير اللغة
        // -----------------------------------------------------------\n        const systemLang = document.getElementById('system-language');
        function applyDashboardLanguage() {
            isEnglish = systemLang.value === 'en';
            if(isEnglish) {
                document.documentElement.setAttribute('dir', 'ltr');
                document.documentElement.setAttribute('lang', 'en');
                document.body.style.fontFamily = "system-ui, -apple-system, sans-serif";
                document.querySelectorAll('[data-en]').forEach(el => el.innerText = el.getAttribute('data-en'));
                document.getElementById('save-btn-text').innerText = "Save Settings Now";
            } else {
                document.documentElement.setAttribute('dir', 'rtl');
                document.documentElement.setAttribute('lang', 'ar');
                document.body.style.fontFamily = "'Tajawal', sans-serif";
                document.querySelectorAll('[data-en]').forEach(el => el.innerText = el.innerText); // Reverts to original HTML text
                document.getElementById('save-btn-text').innerText = "حفظ التعديلات الآن";
            }
            renderWarns(isEnglish ? 'en' : 'ar');
        }
        if(systemLang) {
            systemLang.addEventListener('change', applyDashboardLanguage);
            if(isEnglish) setTimeout(applyDashboardLanguage, 100);
        }

        window.onload = () => { 
            renderWarns('ar'); renderWarns('en'); 
            renderMmFields(); renderAllPanels(); 
            renderLvlRewards(); renderAutoResponders();
            const alert = document.querySelector('.pop-down-alert');
            if(alert) setTimeout(() => alert.style.display = 'none', 5000);
        };
    </script>
</body>
</html>

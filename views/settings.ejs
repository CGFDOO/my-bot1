                        <textarea class="w-full bg-dark-900 border border-dark-700 text-white text-sm rounded-xl p-4 resize-y focus:border-brand outline-none ${lang === 'en' ? 'text-left' : ''}" dir="${lang === 'en' ? 'ltr' : 'rtl'}" rows="3" onchange="${lang === 'ar' ? 'warnDataAr' : 'warnDataEn'}[${index}].dmMessage = this.value">${item.dmMessage}</textarea>
                    </div>
                `;
            });
        }
        function addWarnReason(lang) { 
            if(lang === 'ar') warnDataAr.push({reason: 'سبب جديد', dmMessage: 'لقد تم تحذيرك بسبب...'}); 
            else warnDataEn.push({reason: 'New Reason', dmMessage: 'You have been warned for...'}); 
            renderWarns(lang); 
        }

        // --- محرك أسئلة نافذة الوساطة ---
        function renderMmFields() {
            const container = document.getElementById('mm-fields-ui-container'); 
            container.innerHTML = '';
            if(mmFields.length === 0) {
                container.innerHTML = '<div class="text-center text-slate-500 text-base p-6 border-2 border-dashed border-dark-600 rounded-2xl font-bold">لا توجد أسئلة للنافذة حالياً. العميل سيفتح التذكرة فوراً.</div>';
                return;
            }
            mmFields.forEach((field, index) => {
                container.innerHTML += `
                    <div class="bg-dark-800 p-6 rounded-2xl border border-dark-600 mb-5 relative shadow-md">

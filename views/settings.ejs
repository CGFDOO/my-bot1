                            </div>
                            <div class="bg-dark-900/50 p-6 rounded-2xl border border-dark-700 shadow-md">
                                <label class="block text-sm font-bold text-emerald-400 mb-3" data-en="Trade Approve Roles">رتب الموافقة على التريد</label>
                                <select name="role_tradeApproveRoleIds" multiple class="w-full h-48 bg-dark-800 border border-dark-600 rounded-xl py-3 px-4 text-white custom-scrollbar focus:border-brand outline-none">
                                    <% serverRoles.forEach(role => { %> 
                                        <option value="<%= role.id %>" <%= (config.roles?.tradeApproveRoleIds || []).includes(role.id) ? 'selected' : '' %>><%= role.name %></option> 
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

<div id="section-protection" class="settings-section max-w-5xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-black text-white mb-6 border-b border-dark-700 pb-4" data-en="Anti-Nuke & Security 🛡️">الحماية الصارمة والـ Anti-Nuke 🛡️</h2>
                    
                    <div class="glass-card rounded-3xl p-6 md:p-8 mb-8 border-t-4 border-t-red-500 shadow-lg">
                        
                        <div class="bg-red-900/20 border border-red-500/40 p-6 rounded-2xl mb-8 relative overflow-hidden">
                            <div class="absolute top-0 right-0 bg-red-600 text-white text-xs font-bold px-4 py-1 rounded-bl-xl">ULTIMATE SECURITY</div>
                            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                                <div>
                                    <h3 class="text-2xl font-black text-red-400 mb-2" data-en="Anti-Nuke (Anti-Hack)">نظام الحماية ضد التخريب (Anti-Nuke)</h3>
                                    <p class="text-sm text-slate-300 font-bold">يقوم النظام بسحب جميع رتب المخرب فوراً (إجباري) لإيقافه، مع تطبيق عقوبة إضافية وتصليح ما تم تخريبه.</p>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" name="prot_antiNukeEnabled" <%= config.protection?.antiNukeEnabled ? 'checked' : '' %>>
                                    <span class="slider"></span>
                                </label>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 pt-6 border-t border-red-500/20">
                                <div>
                                    <label class="block text-sm font-bold text-slate-300 mb-2">حد الحذف/الباند في الدقيقة</label>
                                    <input type="number" name="prot_nukeThreshold" value="<%= config.protection?.nukeThreshold || 3 %>" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3 px-4 text-white font-bold input-glow text-center">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-slate-300 mb-2">العقوبة الإضافية للمخرب</label>
                                    <select name="prot_nukeAction" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3.5 px-4 text-red-400 font-bold cursor-pointer input-glow">
                                        <option value="strip_only" <%= config.protection?.nukeAction === 'strip_only' ? 'selected' : '' %>>سحب الرتب فقط 🛡️</option>
                                        <option value="ban" <%= config.protection?.nukeAction === 'ban' ? 'selected' : '' %>>سحب الرتب + حظر (Ban) 🔨</option>
                                        <option value="kick" <%= config.protection?.nukeAction === 'kick' ? 'selected' : '' %>>سحب الرتب + طرد (Kick) 👢</option>
                                        <option value="timeout" <%= config.protection?.nukeAction === 'timeout' ? 'selected' : '' %>>سحب الرتب + تايم أوت ⏳</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                            <div class="flex items-center justify-between p-5 bg-dark-800 rounded-2xl border border-dark-600">
                                <div><h3 class="text-lg font-bold text-white mb-1">منع الروابط (Anti-Link)</h3></div>
                                <label class="switch"><input type="checkbox" name="prot_antiLink" <%= config.protection?.antiLinkEnabled ? 'checked' : '' %>><span class="slider"></span></label>
                            </div>
                            <div class="flex items-center justify-between p-5 bg-dark-800 rounded-2xl border border-dark-600">
                                <div><h3 class="text-lg font-bold text-white mb-1">منع السبام (Anti-Spam)</h3></div>
                                <label class="switch"><input type="checkbox" name="prot_antiSpam" <%= config.protection?.antiSpamEnabled ? 'checked' : '' %>><span class="slider"></span></label>
                            </div>
                        </div>

                        <hr class="border-dark-700 my-6">
                        <h3 class="text-xl font-bold text-brand-light mb-4">أمر إعطاء رتبة للجميع (Mass Role)</h3>
                        <div class="bg-dark-900/50 p-5 rounded-2xl border border-dark-700 shadow-md">

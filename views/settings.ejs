                                    <option value="" data-en="-- Select Channel --">-- اختر الروم --</option>
                                    <% textChannels.forEach(ch => { %> 
                                        <option value="<%= ch.id %>" <%= config.middlemanSystem?.panelChannelId === ch.id ? 'selected' : '' %>>💬 <%= ch.name %></option> 
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <h3 class="text-2xl font-bold text-white mb-6 border-b border-dark-700 pb-2" data-en="🖼️ Outer Panel Design">🖼️ تصميم البانل الخارجي</h3>

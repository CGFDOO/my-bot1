                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-2" data-en="Button Label">اسم الزر (Button Label)</label>
                                <input type="text" name="mm_buttonLabel" value="<%= config.middlemanSystem?.buttonLabel || 'طلب وسيط 🛡️' %>" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3 px-4 text-white font-bold input-glow">

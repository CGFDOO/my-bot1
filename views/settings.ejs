                                    <% textChannels.forEach(ch => { %> 
                                        <option value="<%= ch.id %>" <%= config.ticketControls?.ticketLogChannelId === ch.id ? 'selected' : '' %>>💬 <%= ch.name %></option> 
                                    <% }) %>
                                </select>
                                <p class="text-sm text-slate-400 font-bold" data-en="Detailed logs for every ticket action will be sent here.">سيتم إرسال سجلات مفصلة لكل تذكرة إلى هذا الروم (من قام بفتحها، إغلاقها، أو استلامها).</p>
                            </div>

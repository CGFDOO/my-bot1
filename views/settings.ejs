<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SYSTEM CONTROL | إعدادات الإمبراطورية</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { 
                        sans: ['Tajawal', 'sans-serif'] 
                    },
                    colors: { 
                        brand: { DEFAULT: '#5865F2', dark: '#4752C4', light: '#7289DA' }, 
                        dark: { 900: '#0b0f19', 800: '#151b2b', 700: '#1f2937', 600: '#334155' } 
                    }
                }
            }
        }
    </script>

    <style>
        body { background-color: #0b0f19; color: #f8fafc; overflow-x: hidden; scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0f19; }
        ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #5865F2; }
        
        .glass-card { background: rgba(21, 27, 43, 0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.05); box-shadow: 0 10px 40px -10px rgba(0,0,0,0.6); }
        .input-glow:focus { box-shadow: 0 0 0 3px rgba(88, 101, 242, 0.3); border-color: #5865F2; outline: none; }
        .settings-section { display: none; animation: fadeIn 0.4s ease forwards; }
        .settings-section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

        .switch { position: relative; display: inline-block; width: 54px; height: 28px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #374151; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 20px; width: 20px; right: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: #10B981; }
        input:checked + .slider:before { transform: translateX(-26px); }

        input[type="radio"] { appearance: auto; width: 1.2rem; height: 1.2rem; accent-color: #5865F2; cursor: pointer; }
        @keyframes popDown { 0% { top: -100px; opacity: 0; } 100% { top: 20px; opacity: 1; } }
        .pop-down-alert { animation: popDown 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    </style>
</head>

<% 
    let textChannels = []; let voiceChannels = []; let categories = []; let serverRoles = [];
    let guildName = "Unknown Server"; let guildIconUrl = "https://cdn.discordapp.com/embed/avatars/0.png";
    if (bot && guildId) {
        const currentGuild = bot.guilds.cache.get(guildId);
        if (currentGuild) {
            guildName = currentGuild.name;
            if (currentGuild.icon) guildIconUrl = `https://cdn.discordapp.com/icons/${guildId}/${currentGuild.icon}.png`;
            textChannels = currentGuild.channels.cache.filter(c => c.type === 0 || c.type === 5 || c.type === 15).sort((a,b) => a.position - b.position).map(c => ({ id: c.id, name: c.name }));
            categories = currentGuild.channels.cache.filter(c => c.type === 4).sort((a,b) => a.position - b.position).map(c => ({ id: c.id, name: c.name }));
            serverRoles = currentGuild.roles.cache.filter(r => r.id !== guildId).sort((a,b) => b.position - a.position).map(r => ({ id: r.id, name: r.name }));
        }
    }
%>

<body class="flex flex-col md:flex-row h-screen overflow-hidden selection:bg-brand selection:text-white relative">

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="fixed left-1/2 transform -translate-x-1/2 z-[200] bg-emerald-500 text-white px-8 py-4 rounded-2xl flex items-center shadow-[0_10px_40px_rgba(16,185,129,0.5)] border-2 border-emerald-400 pop-down-alert cursor-pointer" onclick="this.style.display='none'">
            <span class="text-3xl ml-4">✅</span>
            <div><h4 class="font-black text-xl" data-en="Changes Saved Successfully!">تم حفظ التغييرات بنجاح!</h4></div>
        </div>
    <% } %>

    <header class="md:hidden flex items-center justify-between bg-dark-800 border-b border-dark-700 p-4 z-40 shadow-md">
        <div class="flex items-center space-x-3 space-x-reverse">
            <img src="<%= guildIconUrl %>" class="w-10 h-10 rounded-lg border border-dark-600 object-cover">
            <h1 class="text-lg font-black text-white">SYSTEM <span class="text-brand">CONTROL</span></h1>
        </div>
        <button onclick="toggleMobileSidebar()" class="text-white bg-dark-700 p-2 rounded-lg hover:bg-dark-600 focus:outline-none transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
    </header>

    <aside id="sidebar" class="fixed inset-y-0 right-0 transform translate-x-full md:relative md:translate-x-0 transition duration-300 ease-in-out w-72 flex-shrink-0 border-l border-dark-700 bg-dark-800 flex flex-col z-[60] shadow-[5px_0_20px_rgba(0,0,0,0.5)]">
        <button onclick="toggleMobileSidebar()" class="md:hidden absolute top-4 left-4 text-red-400 bg-red-500/10 p-3 rounded-lg hover:bg-red-500 hover:text-white transition-colors border border-red-500/30 z-[70]">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="h-24 flex flex-col items-center justify-center border-b border-dark-700 bg-dark-900/60 relative overflow-hidden">
            <h1 class="text-2xl font-black text-white tracking-wider relative z-10" data-en="SYSTEM CONTROL">SYSTEM <span class="text-brand">CONTROL</span></h1>
        </div>
        
        <nav class="flex-1 overflow-y-auto py-6 px-4 space-y-2 custom-scrollbar" id="sidebar-nav">
            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 px-2" data-en="Basics & AI">الأساسيات والذكاء</div>
            <button onclick="switchSection('general')" class="nav-btn active-nav w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all bg-brand text-white font-bold" data-target="general">
                <span class="text-lg">⚙️</span> <span data-en="General & Colors">الإعدادات والألوان</span>
            </button>
            <button onclick="switchSection('ai_system')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-amber-400 hover:bg-dark-700 font-bold" data-target="ai_system">
                <span class="text-lg">✨</span> <span data-en="AI System">الذكاء الاصطناعي (AI)</span>
            </button>
            <button onclick="switchSection('live_embed')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="live_embed">
                <span class="text-lg">🎨</span> <span data-en="Live Embed">صانع الإيمبد الفوري</span>
            </button>

            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 mt-8 px-2" data-en="Tickets & Middleman">التذاكر والمقاطعة</div>
            <button onclick="switchSection('middleman')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="middleman">
                <span class="text-lg">⚖️</span> <span data-en="Middleman System">نظام الوساطة (المعزول)</span>
            </button>
            <button onclick="switchSection('custom_panels')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="custom_panels">
                <span class="text-lg">🎫</span> <span data-en="Dynamic Panels">البانلات الديناميكية</span>
            </button>
            <button onclick="switchSection('ticket_controls')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="ticket_controls">
                <span class="text-lg">🛠️</span> <span data-en="Ticket Controls">التحكم الداخلي للتكت</span>
            </button>

            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 mt-8 px-2" data-en="Management">الإدارة والمتابعة</div>
            <button onclick="switchSection('system_point')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-sky-400 hover:bg-dark-700 font-bold" data-target="system_point">
                <span class="text-lg">🎯</span> <span data-en="System Points">نظام السيستم بوينت</span>
            </button>
            <button onclick="switchSection('invites')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-indigo-400 hover:bg-dark-700 font-bold" data-target="invites">
                <span class="text-lg">📩</span> <span data-en="Invite System">نظام الدعوات (Invites)</span>
            </button>
            <button onclick="switchSection('warnings')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-orange-400 hover:bg-dark-700 font-bold" data-target="warnings">
                <span class="text-lg">⚠️</span> <span data-en="Warnings Panel">نظام التحذيرات</span>
            </button>
            <button onclick="switchSection('commands')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="commands">
                <span class="text-lg">⌨️</span> <span data-en="Custom Commands">تخصيص الأوامر</span>
            </button>
            <button onclick="switchSection('auto_responders')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-fuchsia-400 hover:bg-dark-700 font-bold" data-target="auto_responders">
                <span class="text-lg">💬</span> <span data-en="Auto Responders">الردود التلقائية والخط</span>
            </button>
            <button onclick="switchSection('logs')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="logs">
                <span class="text-lg">📝</span> <span data-en="Server Logs">السجلات الدقيقة</span>
            </button>
            <button onclick="switchSection('roles')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-slate-400 hover:bg-dark-700 hover:text-white font-bold" data-target="roles">
                <span class="text-lg">👑</span> <span data-en="Roles & Permissions">الرتب والصلاحيات العليا</span>
            </button>

            <div class="text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 mt-8 px-2" data-en="Protection & Interaction">الحماية والتفاعل</div>
            <button onclick="switchSection('protection')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-red-500 hover:bg-dark-700 hover:text-white font-bold" data-target="protection">
                <span class="text-lg">🛡️</span> <span data-en="Anti-Nuke & Protections">الحماية الشاملة</span>
            </button>
            <button onclick="switchSection('welcome')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-pink-400 hover:bg-dark-700 font-bold" data-target="welcome">
                <span class="text-lg">👋</span> <span data-en="Welcome & Leave">الترحيب المتطور (Pro)</span>
            </button>
            <button onclick="switchSection('economy')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-green-400 hover:bg-dark-700 font-bold" data-target="economy">
                <span class="text-lg">💰</span> <span data-en="Economy">الاقتصاد والجوائز</span>
            </button>
            <button onclick="switchSection('leveling')" class="nav-btn w-full flex items-center space-x-3 space-x-reverse px-4 py-3.5 rounded-xl transition-all text-blue-400 hover:bg-dark-700 font-bold" data-target="leveling">
                <span class="text-lg">📈</span> <span data-en="Leveling">نظام اللفلات (Pro)</span>
            </button>
        </nav>
    </aside>

    <div id="sidebar-overlay" onclick="toggleMobileSidebar()" class="fixed inset-0 bg-black/80 z-40 hidden md:hidden backdrop-blur-sm transition-all"></div>

    <main class="flex-1 flex flex-col h-[calc(100vh-72px)] md:h-screen relative bg-dark-900">
        <header class="hidden md:flex h-24 flex-shrink-0 border-b border-dark-700 bg-dark-800/80 backdrop-blur-xl items-center px-10 z-10 shadow-md relative">
            <div class="flex items-center space-x-5 space-x-reverse z-10">
                <img src="<%= guildIconUrl %>" class="w-14 h-14 rounded-xl border border-dark-600 shadow-lg object-cover">
                <div>
                    <h2 class="text-2xl font-black text-white tracking-wide"><%= guildName %></h2>
                    <p class="text-xs text-emerald-400 mt-1 font-bold tracking-widest">SYSTEM ACTIVE 🟢</p>
                </div>
            </div>
        </header>

        <button type="button" onclick="submitMegaForm()" class="fixed bottom-8 left-8 z-[100] flex items-center px-8 py-5 bg-emerald-500 hover:bg-emerald-400 text-dark-900 text-xl font-black rounded-2xl shadow-[0_0_40px_rgba(16,185,129,0.4)] transition-all transform hover:-translate-y-2 hover:scale-105 border border-emerald-400/50">
            <span class="mr-3 ml-2 text-3xl">💾</span> <span id="save-btn-text" data-en="Save Settings Now">حفظ التعديلات الآن</span>
        </button>

        <div class="flex-1 overflow-y-auto p-4 md:p-10 z-10 custom-scrollbar relative" id="main-scroll-area">
            <form action="/settings/<%= guildId %>/save" method="POST" id="mega-settings-form">
                
                <div id="hidden-data-container" style="display: none;">
                    <input type="hidden" name="warn_reasonsDataAr" id="warn_reasonsDataAr">
                    <input type="hidden" name="warn_reasonsDataEn" id="warn_reasonsDataEn">
                    <input type="hidden" name="mm_modalFieldsData" id="mm_modalFieldsData">
                    <input type="hidden" name="ticketPanelsData" id="ticketPanelsData">
                    <input type="hidden" name="lvl_roleRewardsData" id="lvl_roleRewardsData">
                    <input type="hidden" name="autoRespondersData" id="autoRespondersData">
                    <input type="hidden" name="autoLineData" id="autoLineData">
                </div>

                <div id="section-general" class="settings-section active max-w-5xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-black text-white mb-6 border-b border-dark-700 pb-4" data-en="General Settings & Colors ⚙️">الإعدادات العامة والألوان ⚙️</h2>
                    <div class="glass-card rounded-3xl p-6 md:p-8 mb-8 border-t-4 border-t-brand">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-3" data-en="Bot Prefix">البادئة (Prefix)</label>
                                <input type="text" name="prefix" value="<%= config.prefix || '!' %>" required class="w-full bg-dark-900 border border-dark-700 rounded-xl py-3 px-5 text-white input-glow font-mono text-2xl text-center font-black">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-3" data-en="Dashboard Language">لغة النظام الأساسية للداشبورد</label>
                                <select name="language" id="system-language" class="w-full bg-dark-900 border border-dark-700 rounded-xl py-4 px-5 text-white input-glow font-bold text-lg cursor-pointer">
                                    <option value="ar" <%= config.language === 'ar' ? 'selected' : '' %>>🇸🇦 العربية (Arabic)</option>
                                    <option value="en" <%= config.language === 'en' ? 'selected' : '' %>>🇺🇸 الإنجليزية (English)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="section-system_point" class="settings-section max-w-5xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-black text-sky-400 mb-6 border-b border-dark-700 pb-4" data-en="System Points 🎯">نظام نقاط الإدارة (System Point) 🎯</h2>
                    <div class="glass-card rounded-3xl p-6 md:p-8 mb-8 border-t-4 border-t-sky-500 shadow-lg">
                        <div class="flex flex-col md:flex-row items-start md:items-center justify-between bg-dark-900/80 p-5 rounded-2xl border border-sky-500/30 mb-8 gap-4">
                            <div>
                                <h3 class="text-xl font-bold text-white mb-1" data-en="Enable System Point">تفعيل نظام نقاط الإدارة</h3>
                                <p class="text-sm text-slate-400" data-en="Tracks all admin actions automatically.">بيحسب عدد التكتات اللي استلمها كل إداري تلقائياً.</p>
                            </div>
                            <label class="switch">
                                <input type="checkbox" name="syspt_enabled" id="syspt_enabled" <%= config.systemPoint?.enabled ? 'checked' : '' %>>
                                <span class="slider"></span>
                            </label>
                        </div>
                        <div class="grid grid-cols-1 gap-6 mb-8">
                            <div class="bg-dark-900/50 p-5 rounded-2xl border border-dark-700">
                                <label class="block text-sm font-bold text-sky-400 mb-3" data-en="System Point Channel">روم السيستم بوينت (الأساسية اللي فيها الـ Threads)</label>
                                <select name="syspt_channelId" class="w-full bg-dark-800 border border-dark-600 rounded-xl py-4 px-4 text-sky-50 input-glow cursor-pointer font-bold text-lg">
                                    <option value="">-- اختر الروم --</option>
                                    <% textChannels.forEach(ch => { %> 
                                        <option value="<%= ch.id %>" <%= config.systemPoint?.channelId === ch.id ? 'selected' : '' %>>💬 <%= ch.name %></option> 
                                    <% }) %>
                                </select>
                                <p class="text-xs text-slate-400 mt-2">البوت هيتفاعل في الروم دي بالأمر <code>!systempoint @admin</code> عشان يكريت إيمبد الإحصائيات بأزرار (Today, Week, Month, Year, Reset).</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="section-invites" class="settings-section max-w-5xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-black text-indigo-400 mb-6 border-b border-dark-700 pb-4" data-en="Invite System 📩">نظام الدعوات 📩</h2>
                    <div class="glass-card rounded-3xl p-6 md:p-8 mb-8 border-t-4 border-t-indigo-500 shadow-lg">
                        <div class="bg-dark-900/50 p-6 rounded-2xl border border-dark-700 shadow-md">
                            <h3 class="text-xl font-bold text-white mb-4">إعدادات أمر الدعوات</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-bold text-slate-300 mb-2">الأمر الأساسي للدعوات</label>
                                    <input type="text" name="inv_command" value="<%= config.invites?.command || 'invite' %>" class="w-full bg-dark-800 border border-dark-600 rounded-xl py-3 px-4 text-white font-mono text-center">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-slate-300 mb-2">الأسماء المستعارة (Aliases)</label>
                                    <input type="text" name="inv_aliases" value="<%= config.invites?.aliases || 'inv, invites' %>" class="w-full bg-dark-800 border border-dark-600 rounded-xl py-3 px-4 text-white font-mono text-center" placeholder="inv, invites">
                                </div>
                            </div>
                            <p class="text-xs text-slate-400 mt-4">الإيمبد هيعرض: Real Invites, Fake Invites, Left Invites, Total Invites (منفصل تماماً عن اللفلات).</p>
                        </div>
                    </div>
                </div>

                <div id="section-welcome" class="settings-section max-w-5xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-black text-white mb-6 border-b border-dark-700 pb-4" data-en="Welcome & Leave System 👋">الترحيب المتطور 👋</h2>
                    <div class="glass-card rounded-3xl p-6 md:p-8 mb-8 border-t-4 border-t-pink-500 shadow-lg">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 border-b border-dark-700 pb-4 gap-4">
                            <div>
                                <span class="font-black text-2xl text-pink-400 block mb-1">تفعيل نظام الترحيب المتطور بالصور</span>
                            </div>
                            <label class="switch">
                                <input type="checkbox" name="wel_welcomeEnabled" <%= config.welcomeSystem?.welcomeEnabled !== false ? 'checked' : '' %>>
                                <span class="slider"></span>
                            </label>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-6">
                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-2">روم إرسال الترحيب</label>
                                <select name="wel_welcomeChannelId" class="w-full bg-dark-800 border border-dark-600 rounded-xl py-3.5 px-4 text-white font-bold cursor-pointer input-glow">
                                    <option value="">-- اختر الروم --</option>
                                    <% textChannels.forEach(ch => { %>
                                        <option value="<%= ch.id %>" <%= config.welcomeSystem?.welcomeChannelId === ch.id ? 'selected' : '' %>>💬 <%= ch.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-300 mb-2">رابط صورة الخلفية الأساسية</label>
                                <input type="text" name="wel_backgroundUrl" value="<%= config.welcomeSystem?.backgroundUrl || '' %>" placeholder="https://..." dir="ltr" class="w-full bg-dark-800 border border-dark-600 rounded-xl py-3.5 px-4 text-white text-left font-mono input-glow">
                            </div>
                        </div>

                        <div class="bg-dark-800 p-6 rounded-2xl border border-pink-500/30 mb-6 shadow-sm">
                            <h3 class="text-lg font-bold text-brand-light mb-3">🎨 تصميم الصورة (شبه برو بوت)</h3>

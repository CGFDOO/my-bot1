                                        <option value="<%= ch.id %>" <%= config.ticketControls?.transcriptChannelId === ch.id ? 'selected' : '' %>>💬 <%= ch.name %></option> 
                                    <% }) %>
                                </select>
                            </div>

                            <div class="md:col-span-2 bg-dark-900/60 p-6 rounded-2xl border-2 border-blue-500/30 shadow-lg mt-2">
                                <label class="block text-lg font-black text-blue-400 mb-3" data-en="📝 Ticket Logs Channel (Open, Close, Claim)">📝 روم لوج التذاكر الداخلي (فتح، إغلاق، استلام)</label>
